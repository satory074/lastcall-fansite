---
import { getCollection } from "astro:content";
import Layout from "../../components/Layout.astro";
import PersonCard from "../../components/PersonCard.astro";
import { siteLink } from "../../lib/url";

const all = (await getCollection("cinderellas")).sort((a, b) =>
  a.data.episodeId.localeCompare(b.data.episodeId)
);
const passers = all.filter((c) => c.data.result === "pass");
const failers = all.filter((c) => c.data.result === "fail");
---

<Layout title="シンデレラ一覧" description="LAST CALL に出演した全シンデレラ（合格者・不合格者）の一覧とSNS。">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-10 space-y-10">
    <header class="space-y-2">
      <p class="font-display tracking-[0.3em] text-xs text-[var(--color-gold)]">CINDERELLAS</p>
      <h1 class="text-2xl sm:text-3xl font-bold">シンデレラ一覧</h1>
      <p class="text-sm text-[var(--color-text-muted)]">
        全 {all.length} 名（合格 {passers.length} ／ 不合格 {failers.length}）
      </p>
    </header>

    <section class="space-y-4">
      <h2 class="font-display tracking-widest text-sm uppercase text-[var(--color-gold)]">
        Passed
      </h2>
      {passers.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {passers.map((c) => (
            <PersonCard
              name={c.data.name}
              href={siteLink(`/cinderellas/${c.id}/`)}
              subtitle={c.data.age ? `${c.data.age}歳` : undefined}
              meta={`#${c.data.episodeId} 出演`}
              badge={{ label: "LAST CALL", tone: "pass" }}
              sns={c.data.sns}
            />
          ))}
        </div>
      ) : (
        <p class="text-sm text-[var(--color-text-muted)]">合格者データを準備中です。</p>
      )}
    </section>

    <section class="space-y-4">
      <h2 class="font-display tracking-widest text-sm uppercase text-[var(--color-text-muted)]">
        Nothing
      </h2>
      {failers.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {failers.map((c) => (
            <PersonCard
              name={c.data.name}
              href={siteLink(`/cinderellas/${c.id}/`)}
              subtitle={c.data.age ? `${c.data.age}歳` : undefined}
              meta={`#${c.data.episodeId} 出演`}
              badge={{ label: "NOTHING", tone: "fail" }}
              sns={c.data.sns}
            />
          ))}
        </div>
      ) : (
        <p class="text-sm text-[var(--color-text-muted)]">データを準備中です。</p>
      )}
    </section>
  </div>
</Layout>
