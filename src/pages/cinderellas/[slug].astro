---
import { getCollection } from "astro:content";
import Layout from "../../components/Layout.astro";
import SnsLinks from "../../components/SnsLinks.astro";
import EpisodeCard from "../../components/EpisodeCard.astro";
import DivergingBar from "../../components/DivergingBar.astro";

export async function getStaticPaths() {
  const cinderellas = await getCollection("cinderellas");
  return cinderellas.map((c) => ({
    params: { slug: c.id },
    props: { cinderella: c },
  }));
}

const { cinderella } = Astro.props;

const episodes = await getCollection("episodes");
const appearance = episodes.find((ep) => ep.data.cinderella.id === cinderella.id);

// per-cinderella tally (her own episode, final votes only)
let pass = 0;
let fail = 0;
let unknown = 0;
if (appearance) {
  const finals = appearance.data.votes.filter((v) => v.round === "final");
  pass = finals.filter((v) => v.vote === "LAST CALL").length;
  fail = finals.filter((v) => v.vote === "NOTHING" || v.vote === "NO CALL").length;
  // judge count = 14 fixed; unknown = 14 - recorded
  const judgesCount = (await getCollection("judges")).length;
  unknown = Math.max(0, judgesCount - finals.length);
}
const hasData = pass + fail > 0;
---

<Layout
  title={cinderella.data.name}
  description={`LAST CALL #${cinderella.data.episodeId} に出演したシンデレラ「${cinderella.data.name}」のプロフィールと審査結果。`}
>
  <article class="max-w-4xl mx-auto px-5 sm:px-8 py-12 sm:py-16 space-y-12">
    <header class="space-y-5">
      <p class="eyebrow">Cinderella</p>
      <div class="flex flex-wrap items-baseline justify-between gap-3">
        <h1 class="font-display-serif text-[2.25rem] sm:text-[3.25rem] leading-[1.05] text-[var(--color-text)]">
          {cinderella.data.name}
          {cinderella.data.age && (
            <span class="text-base font-sans text-[var(--color-text-muted)] ml-3 tabular-nums align-middle">{cinderella.data.age}歳</span>
          )}
        </h1>
        <span
          class:list={[
            "spoiler font-display tracking-[0.22em] text-[11px] font-semibold px-3 py-1.5 rounded-full",
            cinderella.data.result === "pass"
              ? "bg-[var(--color-gold)] text-black"
              : "bg-[var(--color-surface)] text-[var(--color-text-muted)] border border-[var(--color-border-strong)]",
          ]}
          data-spoiler-level="result"
        >
          {cinderella.data.result === "pass" ? "LAST CALL · 合格" : "NOTHING · 不合格"}
        </span>
      </div>
    </header>

    {hasData && (
      <section class="space-y-3">
        <h2 class="section-eyebrow">Verdict</h2>
        <div class="card p-6">
          <DivergingBar
            pass={pass}
            fail={fail}
            unknown={unknown}
            label="このシンデレラの最終ジャッジ"
            size="lg"
            spoilerLevel="result"
          />
        </div>
      </section>
    )}

    {appearance && (
      <section class="space-y-4">
        <h2 class="section-eyebrow">Appearance</h2>
        <EpisodeCard episode={appearance} variant="feature" />
      </section>
    )}

    {cinderella.data.background && (
      <section class="space-y-3">
        <h2 class="section-eyebrow">Background</h2>
        <p class="spoiler-block text-sm sm:text-base leading-[1.85] text-[var(--color-text)]" data-spoiler-level="comment">
          {cinderella.data.background}
        </p>
      </section>
    )}

    <section class="space-y-3">
      <h2 class="section-eyebrow">SNS</h2>
      <SnsLinks sns={cinderella.data.sns} />
    </section>
  </article>
</Layout>
