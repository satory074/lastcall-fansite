---
import { getCollection } from "astro:content";
import Layout from "../../components/Layout.astro";
import PersonCard from "../../components/PersonCard.astro";
import { siteLink } from "../../lib/url";

const judges = (await getCollection("judges")).sort((a, b) =>
  a.data.name.localeCompare(b.data.name, "ja")
);
---

<Layout title="審査員一覧" description="LAST CALL のレジェンドキャバ嬢 審査員一覧とSNS。">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-10 space-y-6">
    <header class="space-y-2">
      <p class="font-display tracking-[0.3em] text-xs text-[var(--color-gold)]">JUDGES</p>
      <h1 class="text-2xl sm:text-3xl font-bold">審査員一覧</h1>
      <p class="text-sm text-[var(--color-text-muted)]">
        全 {judges.length} 名（固定メンバー）
      </p>
    </header>

    {judges.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {judges.map((j) => (
          <PersonCard
            name={j.data.name}
            href={siteLink(`/judges/${j.id}/`)}
            subtitle={j.data.area ?? j.data.store}
            meta={j.data.age ? `${j.data.age}歳` : undefined}
            sns={j.data.sns}
          />
        ))}
      </div>
    ) : (
      <div class="rounded-lg border border-dashed border-[var(--color-border)] p-10 text-center text-[var(--color-text-muted)]">
        審査員データが未投入です。
      </div>
    )}
  </div>
</Layout>
