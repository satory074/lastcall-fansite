---
import { getCollection, getEntry } from "astro:content";
import type { CollectionEntry } from "astro:content";
import Layout from "../../components/Layout.astro";
import SnsLinks from "../../components/SnsLinks.astro";
import { siteLink } from "../../lib/url";

export async function getStaticPaths() {
  const judges = await getCollection("judges");
  return judges.map((j) => ({
    params: { slug: j.id },
    props: { judge: j },
  }));
}

const { judge } = Astro.props;
const episodes = (await getCollection("episodes")).sort(
  (a, b) => a.data.airedAt.getTime() - b.data.airedAt.getTime()
);

type HistoryRow = {
  episode: CollectionEntry<"episodes">;
  cinderellaName: string;
  round: "first" | "final";
  vote: "LAST CALL" | "NOTHING" | "NO CALL" | "ABSENT";
  comment?: string;
};

const history: HistoryRow[] = [];
for (const ep of episodes) {
  const votesForJudge = ep.data.votes.filter((vv) => vv.judge.id === judge.id);
  if (votesForJudge.length === 0) continue;
  const c = await getEntry(ep.data.cinderella);
  for (const round of ["first", "final"] as const) {
    const v = votesForJudge.find((vv) => vv.round === round);
    if (!v) continue;
    history.push({
      episode: ep,
      cinderellaName: c?.data.name ?? "—",
      round,
      vote: v.vote,
      comment: v.comment,
    });
  }
}

// ラウンド別の集計
const roundTally = (round: "first" | "final") => {
  const list = history.filter((h) => h.round === round);
  return {
    lastCall: list.filter((h) => h.vote === "LAST CALL").length,
    nothing: list.filter((h) => h.vote === "NOTHING").length,
    noCall: list.filter((h) => h.vote === "NO CALL").length,
    absent: list.filter((h) => h.vote === "ABSENT").length,
    total: list.length,
  };
};
const firstTally = roundTally("first");
const finalTally = roundTally("final");

// 合格率は最終ジャッジのみ
const passCount = finalTally.lastCall;
const failCount = finalTally.nothing + finalTally.noCall;
const total = passCount + failCount;
const passRate = total > 0 ? Math.round((passCount / total) * 100) : null;

// ファースト→最終で判定を変えた回数
const flipped = (() => {
  // group history by episode id
  const byEp = new Map<string, { first?: HistoryRow; final?: HistoryRow }>();
  for (const h of history) {
    const slot = byEp.get(h.episode.data.id) ?? {};
    slot[h.round] = h;
    byEp.set(h.episode.data.id, slot);
  }
  let count = 0;
  for (const slot of byEp.values()) {
    if (!slot.first || !slot.final) continue;
    const firstPass = slot.first.vote === "LAST CALL";
    const finalPass = slot.final.vote === "LAST CALL";
    if (firstPass !== finalPass) count++;
  }
  return count;
})();
---

<Layout
  title={judge.data.name}
  description={`LAST CALL 審査員「${judge.data.name}」のプロフィール、SNS、全回投票履歴。`}
>
  <article class="max-w-4xl mx-auto px-4 sm:px-6 py-10 space-y-8">
    <header class="space-y-3">
      <p class="font-display tracking-[0.3em] text-xs text-[var(--color-gold)]">JUDGE</p>
      <h1 class="text-2xl sm:text-3xl font-bold">
        {judge.data.name}
        {judge.data.nameKana && (
          <span class="text-sm text-[var(--color-text-muted)] ml-2 font-normal">
            {judge.data.nameKana}
          </span>
        )}
      </h1>
      <div class="text-sm text-[var(--color-text-muted)] space-x-2">
        {judge.data.age && <span>{judge.data.age}歳</span>}
        {judge.data.area && <span>· {judge.data.area}</span>}
        {judge.data.store && <span>· {judge.data.store}</span>}
      </div>
    </header>

    {judge.data.bio && (
      <section class="space-y-2">
        <h2 class="font-display tracking-widest text-sm text-[var(--color-text-muted)] uppercase">
          Profile
        </h2>
        <p class="text-sm sm:text-base leading-relaxed">{judge.data.bio}</p>
      </section>
    )}

    <section class="space-y-2">
      <h2 class="font-display tracking-widest text-sm text-[var(--color-text-muted)] uppercase">
        SNS
      </h2>
      <SnsLinks sns={judge.data.sns} />
    </section>

    <section class="space-y-3">
      <h2 class="font-display tracking-widest text-sm text-[var(--color-text-muted)] uppercase">
        Voting History
      </h2>

      {(firstTally.total > 0 || finalTally.total > 0) && (
        <div class="grid sm:grid-cols-2 gap-2 text-xs">
          {([
            { label: "ファーストコール", sub: "First Call", t: firstTally },
            { label: "最終ジャッジ", sub: "Final Judgment", t: finalTally },
          ]).map(({ label, sub, t }) => (
            <div class="rounded-md border border-[var(--color-border)] bg-[var(--color-bg-elevated)] px-3 py-2">
              <div class="flex items-center justify-between mb-1">
                <span class="font-semibold text-[var(--color-text)]">{label}</span>
                <span class="text-[10px] text-[var(--color-text-subtle)] uppercase tracking-wider">{sub} · {t.total} 票</span>
              </div>
              <div class="spoiler flex flex-wrap items-center gap-x-3 gap-y-1 text-[var(--color-text-muted)]">
                <span class="inline-flex items-center gap-1">
                  <span class="inline-block w-2 h-2 rounded-full bg-[var(--color-gold)]"></span>
                  LC <span class="font-semibold text-[var(--color-gold)]">{t.lastCall}</span>
                </span>
                <span class="inline-flex items-center gap-1">
                  <span class="inline-block w-2 h-2 rounded-full bg-[var(--color-fail)]"></span>
                  NOTHING <span class="font-semibold text-[var(--color-text)]">{t.nothing}</span>
                </span>
                <span class="inline-flex items-center gap-1">
                  <span class="inline-block w-2 h-2 rounded-full border border-[var(--color-fail)]"></span>
                  NO CALL <span class="font-semibold text-[var(--color-text)]">{t.noCall}</span>
                </span>
                {t.absent > 0 && <span>欠席 {t.absent}</span>}
              </div>
            </div>
          ))}
        </div>
      )}

      {total > 0 && passRate !== null && (
        <p class="spoiler text-xs text-[var(--color-text-muted)]">
          合格率（最終ジャッジ） <span class="text-[var(--color-text)] font-semibold">{passRate}%</span>
          （{passCount} / {total}）
          {flipped > 0 && <span class="ml-2">· ファースト→最終で判定変更 <span class="text-[var(--color-text)] font-semibold">{flipped}</span> 回</span>}
        </p>
      )}

      <div class="overflow-x-auto rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-card)]">
        <table class="min-w-full text-sm">
          <thead class="bg-[var(--color-bg-elevated)] text-[var(--color-text-muted)]">
            <tr>
              <th class="text-left font-medium px-3 py-2 whitespace-nowrap">回</th>
              <th class="text-left font-medium px-3 py-2 whitespace-nowrap">シンデレラ</th>
              <th class="text-left font-medium px-3 py-2 whitespace-nowrap">ラウンド</th>
              <th class="text-left font-medium px-3 py-2 whitespace-nowrap">投票</th>
              <th class="text-left font-medium px-3 py-2">コメント</th>
            </tr>
          </thead>
          <tbody>
            {history.map((h) => (
              <tr class="border-t border-[var(--color-border)]">
                <td class="px-3 py-2 whitespace-nowrap">
                  <a
                    href={siteLink(`/episodes/${h.episode.data.id}/`)}
                    class="hover:text-[var(--color-gold-bright)] transition"
                  >
                    #{h.episode.data.id}
                  </a>
                </td>
                <td class="px-3 py-2 whitespace-nowrap text-[var(--color-text-muted)]">
                  {h.cinderellaName}
                </td>
                <td class="px-3 py-2 whitespace-nowrap text-xs text-[var(--color-text-muted)]">
                  {h.round === "first" ? "ファーストコール" : "最終ジャッジ"}
                </td>
                <td class="px-3 py-2 whitespace-nowrap">
                  {h.vote === "LAST CALL" && (
                    <span class="spoiler inline-flex items-center px-2 py-0.5 rounded bg-[var(--color-gold)] text-black text-xs font-semibold tracking-wider">
                      LAST CALL
                    </span>
                  )}
                  {h.vote === "NOTHING" && (
                    <span class="spoiler inline-flex items-center px-2 py-0.5 rounded bg-[var(--color-fail)] text-white text-xs font-semibold tracking-wider">
                      NOTHING
                    </span>
                  )}
                  {h.vote === "NO CALL" && (
                    <span class="spoiler inline-flex items-center px-2 py-0.5 rounded border border-[var(--color-fail)] text-[var(--color-fail)] text-xs font-semibold tracking-wider">
                      NO CALL
                    </span>
                  )}
                  {h.vote === "ABSENT" && (
                    <span class="spoiler inline-flex items-center px-2 py-0.5 rounded border border-[var(--color-border)] text-[var(--color-text-muted)] text-xs">
                      欠席
                    </span>
                  )}
                </td>
                <td class="px-3 py-2 text-[var(--color-text-muted)]">
                  {h.comment ? <span class="spoiler-block inline-block">{h.comment}</span> : "—"}
                </td>
              </tr>
            ))}
            {history.length === 0 && (
              <tr>
                <td colspan="5" class="px-3 py-6 text-center text-[var(--color-text-muted)]">
                  投票履歴データを準備中です。
                </td>
              </tr>
            )}
          </tbody>
        </table>
      </div>
    </section>
  </article>
</Layout>
