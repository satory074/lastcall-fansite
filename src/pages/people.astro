---
import { getCollection, getEntry } from "astro:content";
import Layout from "../components/Layout.astro";
import PersonCard from "../components/PersonCard.astro";
import { siteLink } from "../lib/url";

// 14名固定の審査員（マトリックス列順）
const judges = (await getCollection("judges")).sort((a, b) =>
  a.data.name.localeCompare(b.data.name, "ja")
);

// シンデレラ（出演回順）
const cinderellas = (await getCollection("cinderellas")).sort((a, b) =>
  a.data.episodeId.localeCompare(b.data.episodeId)
);

// エピソード（新しい順）と各回の投票マップ
const episodes = (await getCollection("episodes")).sort(
  (a, b) => b.data.airedAt.getTime() - a.data.airedAt.getTime()
);

type VoteValue = "LAST CALL" | "NOTHING" | "NO CALL" | "ABSENT" | "UNKNOWN";
type Cell = {
  first: { vote: VoteValue; comment?: string };
  final: { vote: VoteValue; comment?: string };
};

const matrix = await Promise.all(
  episodes.map(async (ep) => {
    const cinderella = await getEntry(ep.data.cinderella);
    const cells: Cell[] = judges.map((j) => {
      const f = ep.data.votes.find((v) => v.judge.id === j.id && v.round === "first");
      const l = ep.data.votes.find((v) => v.judge.id === j.id && v.round === "final");
      return {
        first: { vote: f ? f.vote : "UNKNOWN", comment: f?.comment },
        final: { vote: l ? l.vote : "UNKNOWN", comment: l?.comment },
      };
    });
    // 合否タリーは最終ジャッジのみ
    const passCount = cells.filter((c) => c.final.vote === "LAST CALL").length;
    const failCount = cells.filter(
      (c) => c.final.vote === "NOTHING" || c.final.vote === "NO CALL"
    ).length;
    return {
      episode: ep,
      cinderella,
      cells,
      passCount,
      failCount,
    };
  })
);

// 審査員ごとの累計（最終ジャッジ）と合格率
type JudgeTotals = { lastCall: number; nothing: number; noCall: number; recorded: number };
const judgeTotals: JudgeTotals[] = judges.map((_, idx) => {
  const lastCall = matrix.filter((m) => m.cells[idx].final.vote === "LAST CALL").length;
  const nothing = matrix.filter((m) => m.cells[idx].final.vote === "NOTHING").length;
  const noCall = matrix.filter((m) => m.cells[idx].final.vote === "NO CALL").length;
  return { lastCall, nothing, noCall, recorded: lastCall + nothing + noCall };
});

// 全体集計（最終ジャッジ）
const overallEpisodes = matrix.length;
const overallPass = matrix.reduce((acc, m) => acc + m.passCount, 0);
const overallFail = matrix.reduce((acc, m) => acc + m.failCount, 0);
const overallRecorded = overallPass + overallFail;
const overallPassRate = overallRecorded > 0 ? Math.round((overallPass / overallRecorded) * 100) : null;
---

<Layout
  title="出演者・審査一覧"
  description="LAST CALL の全シンデレラ・14名審査員・各回の審査結果マトリックスを一覧。"
>
  <div class="max-w-6xl mx-auto px-5 sm:px-8 py-12 sm:py-16 space-y-16">
    <header class="space-y-5">
      <p class="eyebrow">People &amp; Votes</p>
      <h1 class="font-display-serif text-3xl sm:text-5xl text-[var(--color-text)]">出演者・審査一覧</h1>
      <p class="text-sm text-[var(--color-text-muted)]">
        シンデレラ <span class="text-[var(--color-text)]">{cinderellas.length}</span> 名
        <span class="text-[var(--color-border-strong)] mx-2">/</span>
        審査員 <span class="text-[var(--color-text)]">{judges.length}</span> 名
        <span class="text-[var(--color-border-strong)] mx-2">/</span>
        配信回 <span class="text-[var(--color-text)]">{episodes.length}</span> 回
      </p>
      <nav class="flex flex-wrap gap-2 text-xs pt-2">
        <a href="#cinderellas" class="px-3 py-1.5 rounded-full border border-[var(--color-border)] hover:border-[var(--color-gold)] hover:text-[var(--color-gold-bright)] transition">
          シンデレラ
        </a>
        <a href="#judges" class="px-3 py-1.5 rounded-full border border-[var(--color-border)] hover:border-[var(--color-gold)] hover:text-[var(--color-gold-bright)] transition">
          審査員
        </a>
        <a href="#matrix" class="px-3 py-1.5 rounded-full border border-[var(--color-border)] hover:border-[var(--color-gold)] hover:text-[var(--color-gold-bright)] transition">
          審査マトリックス
        </a>
      </nav>
    </header>

    <section id="cinderellas" class="space-y-6 scroll-mt-24">
      <h2 class="section-eyebrow">Cinderellas <span class="text-[var(--color-text-subtle)] normal-case tracking-normal text-[10px] ml-2">出演回順</span></h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {cinderellas.map((c) => (
          <PersonCard
            name={c.data.name}
            href={siteLink(`/cinderellas/${c.id}/`)}
            subtitle={c.data.age ? `${c.data.age}歳` : undefined}
            meta={`#${c.data.episodeId} 出演`}
            badge={{
              label: c.data.result === "pass" ? "LAST CALL" : "NOTHING",
              tone: c.data.result === "pass" ? "pass" : "fail",
            }}
            sns={c.data.sns}
          />
        ))}
      </div>
    </section>

    <section id="judges" class="space-y-6 scroll-mt-24">
      <h2 class="section-eyebrow">Judges <span class="text-[var(--color-text-subtle)] normal-case tracking-normal text-[10px] ml-2">固定 14 名</span></h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {judges.map((j) => (
          <PersonCard
            name={j.data.name}
            href={siteLink(`/judges/${j.id}/`)}
            subtitle={j.data.area ?? j.data.store}
            meta={j.data.age ? `${j.data.age}歳` : undefined}
            sns={j.data.sns}
          />
        ))}
      </div>
    </section>

    <section id="matrix" class="space-y-6 scroll-mt-24">
      <div class="flex flex-wrap items-end justify-between gap-3">
        <h2 class="section-eyebrow">Voting Matrix <span class="text-[var(--color-text-subtle)] normal-case tracking-normal text-[10px] ml-2">{episodes.length} × {judges.length}</span></h2>
      </div>
      <p class="text-xs text-[var(--color-text-muted)]">
        縦軸=各回（新しい順）、横軸=審査員。各セルは上=<span class="text-[var(--color-text)]">ファーストコール</span> / 下=<span class="text-[var(--color-text)]">最終ジャッジ</span>。空セルは本編未視聴で投票が記録されていない箇所。
      </p>
      {overallRecorded > 0 && (
        <div class="spoiler flex flex-wrap items-center gap-x-4 gap-y-1 text-xs text-[var(--color-text-muted)] rounded-md border border-[var(--color-border)] bg-[var(--color-bg-elevated)] px-3 py-2">
          <span class="font-semibold text-[var(--color-text)]">全体集計（最終ジャッジ）:</span>
          <span>全 {overallEpisodes} 回</span>
          <span>LAST CALL <span class="font-semibold text-[var(--color-gold)]">{overallPass}</span></span>
          <span>NOTHING/NO CALL <span class="font-semibold text-[var(--color-text)]">{overallFail}</span></span>
          {overallPassRate !== null && <span>合格率 <span class="font-semibold text-[var(--color-text)]">{overallPassRate}%</span></span>}
        </div>
      )}
      <div class="overflow-x-auto rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-card)]">
        <table class="text-xs sm:text-sm">
          <thead class="bg-[var(--color-bg-elevated)] text-[var(--color-text-muted)]">
            <tr>
              <th scope="col" class="text-left font-medium px-3 py-2 whitespace-nowrap sticky left-0 bg-[var(--color-bg-elevated)] z-10">回</th>
              <th scope="col" class="text-left font-medium px-3 py-2 whitespace-nowrap">シンデレラ</th>
              <th scope="col" class="text-center font-medium px-2 py-2 whitespace-nowrap">結果</th>
              {judges.map((j) => (
                <th scope="col" class="text-center font-medium px-2 py-2 whitespace-nowrap">
                  <a href={siteLink(`/judges/${j.id}/`)} class="hover:text-[var(--color-gold-bright)] transition">
                    {j.data.name}
                  </a>
                </th>
              ))}
            </tr>
          </thead>
          <tbody>
            {matrix.map(({ episode, cinderella, cells, passCount, failCount }) => {
              const dateLabel = episode.data.airedAt.toISOString().slice(0, 10);
              const recorded = passCount + failCount;
              const calcResult: "pass" | "fail" | null =
                recorded > 0 ? (passCount >= Math.ceil(recorded / 2) ? "pass" : "fail") : null;
              const result = calcResult ?? cinderella?.data.result ?? null;
              return (
                <tr class="border-t border-[var(--color-border)]">
                  <td class="px-3 py-2 whitespace-nowrap sticky left-0 bg-[var(--color-bg-card)] z-10">
                    <a
                      href={siteLink(`/episodes/${episode.data.id}/`)}
                      class="text-[var(--color-gold)] hover:text-[var(--color-gold-bright)] transition"
                    >
                      #{episode.data.id}
                    </a>
                    <div class="text-[10px] text-[var(--color-text-muted)]">{dateLabel}</div>
                  </td>
                  <td class="px-3 py-2 whitespace-nowrap">
                    {cinderella ? (
                      <a
                        href={siteLink(`/cinderellas/${cinderella.id}/`)}
                        class="hover:text-[var(--color-gold-bright)] transition"
                      >
                        {cinderella.data.name}
                      </a>
                    ) : "—"}
                  </td>
                  <td class="px-2 py-2 text-center whitespace-nowrap">
                    {result ? (
                      <span
                        class:list={[
                          "spoiler inline-flex items-center justify-center w-12 px-1.5 py-0.5 rounded text-[10px] font-semibold tracking-wider",
                          result === "pass"
                            ? "bg-[var(--color-gold)] text-black"
                            : "bg-[var(--color-fail)] text-white",
                        ]}
                      >
                        {result === "pass" ? "PASS" : "NO"}
                      </span>
                    ) : (
                      <span class="text-[var(--color-text-muted)]">—</span>
                    )}
                  </td>
                  {cells.map((cell) => {
                    const titleParts: string[] = [];
                    if (cell.first.comment) titleParts.push(`ファースト: ${cell.first.comment}`);
                    if (cell.final.comment) titleParts.push(`最終: ${cell.final.comment}`);
                    return (
                      <td class="px-2 py-2 text-center whitespace-nowrap align-middle" title={titleParts.join(" / ") || undefined}>
                        <div class="inline-flex flex-col items-center gap-0.5">
                          {(["first", "final"] as const).map((round) => {
                            const v = cell[round].vote;
                            return (
                              <>
                                {v === "LAST CALL" && (
                                  <span class="spoiler inline-flex items-center justify-center w-8 h-4 rounded bg-[var(--color-gold)] text-black text-[10px] font-bold leading-none">LC</span>
                                )}
                                {v === "NOTHING" && (
                                  <span class="spoiler inline-flex items-center justify-center w-8 h-4 rounded bg-[var(--color-fail)] text-white text-[10px] font-bold leading-none">NO</span>
                                )}
                                {v === "NO CALL" && (
                                  <span class="spoiler inline-flex items-center justify-center w-8 h-4 rounded border border-[var(--color-fail)] text-[var(--color-fail)] text-[10px] font-bold leading-none">NC</span>
                                )}
                                {v === "ABSENT" && (
                                  <span class="spoiler inline-flex items-center justify-center w-8 h-4 rounded border border-[var(--color-border)] text-[var(--color-text-muted)] text-[10px] leading-none">—</span>
                                )}
                                {v === "UNKNOWN" && (
                                  <span class="inline-flex items-center justify-center w-8 h-4 rounded border border-dashed border-[var(--color-border)] text-[var(--color-text-muted)] text-[10px] leading-none">?</span>
                                )}
                              </>
                            );
                          })}
                        </div>
                      </td>
                    );
                  })}
                </tr>
              );
            })}
          </tbody>
          {judgeTotals.some((t) => t.recorded > 0) && (
            <tfoot class="border-t-2 border-[var(--color-border-strong)] bg-[var(--color-bg-elevated)] text-[var(--color-text-muted)]">
              <tr>
                <th scope="row" class="text-left font-medium px-3 py-2 whitespace-nowrap sticky left-0 bg-[var(--color-bg-elevated)] z-10">
                  累計
                  <div class="text-[10px] text-[var(--color-text-subtle)] font-normal">最終ジャッジ</div>
                </th>
                <td class="px-3 py-2 text-[10px] text-[var(--color-text-subtle)] whitespace-nowrap">審査員別 LC / NO / NC</td>
                <td class="px-2 py-2 text-center text-[10px]">
                  <span class="spoiler">
                    <span class="text-[var(--color-gold)] font-semibold">{overallPass}</span>
                    /
                    <span class="font-semibold">{overallFail}</span>
                  </span>
                </td>
                {judgeTotals.map((t) => (
                  <td class="px-2 py-2 text-center align-middle">
                    {t.recorded === 0 ? (
                      <span class="text-[10px] text-[var(--color-text-subtle)]">—</span>
                    ) : (
                      <div class="spoiler inline-flex flex-col items-center gap-0 text-[10px] leading-tight">
                        <span class="text-[var(--color-gold)] font-bold">{t.lastCall}</span>
                        <span class="text-[var(--color-text-subtle)]">/</span>
                        <span>{t.nothing}{t.noCall > 0 && <span class="text-[var(--color-fail)]">+{t.noCall}</span>}</span>
                      </div>
                    )}
                  </td>
                ))}
              </tr>
            </tfoot>
          )}
        </table>
      </div>
      <div class="flex flex-wrap items-center gap-4 text-xs text-[var(--color-text-muted)]">
        <span class="inline-flex items-center gap-1.5">
          <span class="inline-flex items-center justify-center w-8 h-4 rounded bg-[var(--color-gold)] text-black text-[10px] font-bold leading-none">LC</span>
          = LAST CALL
        </span>
        <span class="inline-flex items-center gap-1.5">
          <span class="inline-flex items-center justify-center w-8 h-4 rounded bg-[var(--color-fail)] text-white text-[10px] font-bold leading-none">NO</span>
          = NOTHING
        </span>
        <span class="inline-flex items-center gap-1.5">
          <span class="inline-flex items-center justify-center w-8 h-4 rounded border border-[var(--color-fail)] text-[var(--color-fail)] text-[10px] font-bold leading-none">NC</span>
          = NO CALL
        </span>
        <span class="inline-flex items-center gap-1.5">
          <span class="inline-flex items-center justify-center w-8 h-4 rounded border border-dashed border-[var(--color-border)] text-[var(--color-text-muted)] text-[10px] leading-none">?</span>
          = 未確認
        </span>
        <span class="inline-flex items-center gap-1.5">
          <span class="inline-flex items-center justify-center w-8 h-4 rounded border border-[var(--color-border)] text-[var(--color-text-muted)] text-[10px] leading-none">—</span>
          = 欠席
        </span>
        <span class="text-[var(--color-text-muted)]">セル上=ファーストコール / 下=最終ジャッジ</span>
      </div>
    </section>
  </div>
</Layout>
