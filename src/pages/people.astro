---
import { getCollection, getEntry } from "astro:content";
import Layout from "../components/Layout.astro";
import PersonCard from "../components/PersonCard.astro";
import VoteChip from "../components/VoteChip.astro";
import DivergingBar from "../components/DivergingBar.astro";
import StatCard from "../components/StatCard.astro";
import { siteLink } from "../lib/url";

// 14名固定の審査員（マトリックス列順）
const judges = (await getCollection("judges")).sort((a, b) =>
  a.data.name.localeCompare(b.data.name, "ja")
);

// シンデレラ（出演回順）
const cinderellas = (await getCollection("cinderellas")).sort((a, b) =>
  a.data.episodeId.localeCompare(b.data.episodeId)
);

// エピソード（新しい順）と各回の投票マップ
const episodes = (await getCollection("episodes")).sort(
  (a, b) => b.data.airedAt.getTime() - a.data.airedAt.getTime()
);

type VoteValue = "LAST CALL" | "NOTHING" | "NO CALL" | "ABSENT" | "UNKNOWN";
type Cell = {
  first: { vote: VoteValue; comment?: string };
  final: { vote: VoteValue; comment?: string };
};

const matrix = await Promise.all(
  episodes.map(async (ep) => {
    const cinderella = await getEntry(ep.data.cinderella);
    const cells: Cell[] = judges.map((j) => {
      const f = ep.data.votes.find((v) => v.judge.id === j.id && v.round === "first");
      const l = ep.data.votes.find((v) => v.judge.id === j.id && v.round === "final");
      return {
        first: { vote: f ? f.vote : "UNKNOWN", comment: f?.comment },
        final: { vote: l ? l.vote : "UNKNOWN", comment: l?.comment },
      };
    });
    const passCount = cells.filter((c) => c.final.vote === "LAST CALL").length;
    const failCount = cells.filter(
      (c) => c.final.vote === "NOTHING" || c.final.vote === "NO CALL"
    ).length;
    return { episode: ep, cinderella, cells, passCount, failCount };
  })
);

// 審査員ごとの累計
const judgeStats = judges.map((_, idx) => {
  const lastCall = matrix.filter((m) => m.cells[idx].final.vote === "LAST CALL").length;
  const nothing = matrix.filter((m) => m.cells[idx].final.vote === "NOTHING").length;
  const noCall = matrix.filter((m) => m.cells[idx].final.vote === "NO CALL").length;
  const recorded = lastCall + nothing + noCall;
  const passRate = recorded > 0 ? Math.round((lastCall / recorded) * 100) : null;
  return { lastCall, nothing, noCall, recorded, passRate };
});

// 全体集計
const overallEpisodes = matrix.length;
const overallPass = matrix.reduce((acc, m) => acc + m.passCount, 0);
const overallFail = matrix.reduce((acc, m) => acc + m.failCount, 0);
const overallRecorded = overallPass + overallFail;
const overallPassRate = overallRecorded > 0 ? Math.round((overallPass / overallRecorded) * 100) : null;

// 番組としての"合否"回数 (1 episode = 1 verdict)
const passEpisodes = cinderellas.filter((c) => c.data.result === "pass").length;
const failEpisodes = cinderellas.filter((c) => c.data.result === "fail").length;
---

<Layout
  title="出演者・審査一覧"
  description="LAST CALL の全シンデレラ・14名審査員・各回の審査結果マトリックスを一覧。"
>
  <div class="max-w-7xl mx-auto px-5 sm:px-8 py-12 sm:py-16 space-y-16">
    <header class="space-y-5">
      <p class="eyebrow">People &amp; Votes</p>
      <h1 class="font-display-serif text-[2.25rem] sm:text-[3.5rem] leading-[1.05] text-[var(--color-text)]">出演者・審査一覧</h1>
      <p class="text-sm text-[var(--color-text-muted)] leading-relaxed max-w-2xl">
        全 <span class="text-[var(--color-text)] tabular-nums">{episodes.length}</span> 回のシンデレラ
        <span class="mx-1.5 text-[var(--color-border-strong)]">·</span>
        14 名固定審査員
        <span class="mx-1.5 text-[var(--color-border-strong)]">·</span>
        2 ラウンド審査の投票マトリックス。
      </p>
      <nav class="flex flex-wrap gap-2 text-xs pt-1">
        <a href="#cinderellas" class="px-3 py-1.5 rounded-full border border-[var(--color-border)] hover:border-[var(--color-gold)] hover:text-[var(--color-gold-bright)] transition">
          シンデレラ
        </a>
        <a href="#judges" class="px-3 py-1.5 rounded-full border border-[var(--color-border)] hover:border-[var(--color-gold)] hover:text-[var(--color-gold-bright)] transition">
          審査員
        </a>
        <a href="#matrix" class="px-3 py-1.5 rounded-full border border-[var(--color-border)] hover:border-[var(--color-gold)] hover:text-[var(--color-gold-bright)] transition">
          審査マトリックス
        </a>
      </nav>
    </header>

    {/* Cinderellas */}
    <section id="cinderellas" class="space-y-6 scroll-mt-24">
      <div class="flex flex-wrap items-end justify-between gap-3">
        <h2 class="section-eyebrow">Cinderellas <span class="text-[var(--color-text-subtle)] normal-case tracking-normal text-[10px] ml-2">出演回順 · {cinderellas.length} 名</span></h2>
        <span class="spoiler text-[11px] text-[var(--color-text-muted)] tracking-wide" data-spoiler-level="result">
          合格 <span class="text-[var(--color-gold)] font-semibold">{passEpisodes}</span>
          <span class="mx-1 text-[var(--color-border-strong)]">/</span>
          不合格 <span class="font-semibold">{failEpisodes}</span>
        </span>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {cinderellas.map((c) => (
          <PersonCard
            name={c.data.name}
            href={siteLink(`/cinderellas/${c.id}/`)}
            subtitle={c.data.age ? `${c.data.age}歳` : undefined}
            meta={`#${c.data.episodeId} 出演`}
            badge={{
              label: c.data.result === "pass" ? "LAST CALL" : "NOTHING",
              tone: c.data.result === "pass" ? "pass" : "fail",
            }}
            sns={c.data.sns}
          />
        ))}
      </div>
    </section>

    {/* Judges */}
    <section id="judges" class="space-y-6 scroll-mt-24">
      <h2 class="section-eyebrow">Judges <span class="text-[var(--color-text-subtle)] normal-case tracking-normal text-[10px] ml-2">固定 {judges.length} 名</span></h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {judges.map((j, i) => {
          const s = judgeStats[i];
          return (
            <PersonCard
              name={j.data.name}
              href={siteLink(`/judges/${j.id}/`)}
              subtitle={j.data.area ?? j.data.store}
              meta={j.data.age ? `${j.data.age}歳` : undefined}
              sns={j.data.sns}
            >
              {s.recorded > 0 && (
                <Fragment slot="signature">
                  <DivergingBar
                    pass={s.lastCall}
                    fail={s.nothing + s.noCall}
                    label="最終ジャッジ傾向"
                    size="sm"
                    spoilerLevel="vote"
                    showLabels={true}
                  />
                </Fragment>
              )}
            </PersonCard>
          );
        })}
      </div>
    </section>

    {/* Voting Matrix — heatmap */}
    <section id="matrix" class="space-y-6 scroll-mt-24">
      <div class="space-y-3">
        <h2 class="section-eyebrow">Voting Matrix <span class="text-[var(--color-text-subtle)] normal-case tracking-normal text-[10px] ml-2">{episodes.length} 回 × {judges.length} 名審査員</span></h2>
        <p class="text-xs text-[var(--color-text-muted)] leading-relaxed max-w-2xl">
          縦=各回（新しい順）・横=審査員。各セルは上段=<span class="text-[var(--color-text)]">ファーストコール</span> / 下段=<span class="text-[var(--color-text)]">最終ジャッジ</span>。点線輪郭は本編未視聴で未記録のセル。
        </p>
      </div>

      {/* Overall stats banner */}
      {overallRecorded > 0 && (
        <div class="card p-5 sm:p-6 space-y-5">
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 sm:gap-4">
            <StatCard label="Episodes" value={overallEpisodes} sublabel="配信済み" />
            <StatCard
              label="合格率"
              value={overallPassRate !== null ? `${overallPassRate}%` : "—"}
              sublabel={`${overallPass} / ${overallRecorded} 票`}
              accent="gold"
              spoiler
              spoilerLevel="result"
            />
            <StatCard label="LAST CALL" value={overallPass} sublabel="最終 合格判定票" accent="gold" spoiler spoilerLevel="result" />
            <StatCard label="NOTHING / NC" value={overallFail} sublabel="最終 不合格判定票" spoiler spoilerLevel="result" />
          </div>
          <DivergingBar
            pass={overallPass}
            fail={overallFail}
            label="全エピソードの最終ジャッジ合計"
            size="lg"
            spoilerLevel="result"
          />
        </div>
      )}

      {/* Legend */}
      <div class="flex flex-wrap items-center gap-3 sm:gap-4 text-[10px] text-[var(--color-text-subtle)] tracking-wider">
        <span class="inline-flex items-center gap-1.5"><VoteChip vote="LAST CALL" size="xs" spoiler={false} /> LC</span>
        <span class="inline-flex items-center gap-1.5"><VoteChip vote="NOTHING" size="xs" spoiler={false} /> NOTHING</span>
        <span class="inline-flex items-center gap-1.5"><VoteChip vote="NO CALL" size="xs" spoiler={false} /> NO CALL</span>
        <span class="inline-flex items-center gap-1.5"><VoteChip vote="ABSENT" size="xs" spoiler={false} /> 欠席</span>
        <span class="inline-flex items-center gap-1.5"><VoteChip vote="UNKNOWN" size="xs" spoiler={false} /> 未確認</span>
        <span>上=ファースト / 下=最終</span>
      </div>

      {/* Heatmap matrix */}
      <div class="overflow-x-auto rounded-xl border border-[var(--color-border)] bg-[var(--color-card)]">
        <table class="text-xs lc-matrix">
          <thead class="bg-[var(--color-surface)] text-[var(--color-text-muted)]">
            <tr>
              <th scope="col" class="text-left font-medium px-3 py-3 whitespace-nowrap sticky left-0 z-20 bg-[var(--color-surface)]">回</th>
              <th scope="col" class="text-left font-medium px-3 py-3 whitespace-nowrap sticky left-[60px] z-20 bg-[var(--color-surface)]">シンデレラ</th>
              <th scope="col" class="text-center font-medium px-3 py-3 whitespace-nowrap">結果</th>
              {judges.map((j) => (
                <th scope="col" class="text-center font-medium px-2 py-3 whitespace-nowrap">
                  <a href={siteLink(`/judges/${j.id}/`)} class="hover:text-[var(--color-gold-bright)] transition inline-block max-w-[64px] truncate text-[11px]">
                    {j.data.name}
                  </a>
                </th>
              ))}
            </tr>
          </thead>
          <tbody>
            {matrix.map(({ episode, cinderella, cells, passCount, failCount }) => {
              const dateLabel = episode.data.airedAt.toISOString().slice(0, 10);
              const recorded = passCount + failCount;
              const calcResult: "pass" | "fail" | null =
                recorded > 0 ? (passCount >= Math.ceil(recorded / 2) ? "pass" : "fail") : null;
              const result = calcResult ?? cinderella?.data.result ?? null;
              return (
                <tr class="border-t border-[var(--color-border)] hover:bg-[color-mix(in_oklab,var(--color-gold)_3%,transparent)] transition">
                  <td class="px-3 py-2.5 whitespace-nowrap sticky left-0 z-10 bg-[var(--color-card)]">
                    <a
                      href={siteLink(`/episodes/${episode.data.id}/`)}
                      class="text-[var(--color-gold)] hover:text-[var(--color-gold-bright)] transition font-semibold tabular-nums"
                    >
                      #{episode.data.id}
                    </a>
                    <div class="text-[9px] text-[var(--color-text-subtle)] tabular-nums">{dateLabel.slice(5)}</div>
                  </td>
                  <td class="px-3 py-2.5 whitespace-nowrap sticky left-[60px] z-10 bg-[var(--color-card)]">
                    {cinderella ? (
                      <a
                        href={siteLink(`/cinderellas/${cinderella.id}/`)}
                        class="text-[var(--color-text)] hover:text-[var(--color-gold-bright)] transition text-[12px]"
                      >
                        {cinderella.data.name}
                      </a>
                    ) : <span class="text-[var(--color-text-subtle)]">—</span>}
                  </td>
                  <td class="px-3 py-2.5 text-center whitespace-nowrap">
                    {result ? (
                      <span
                        class:list={[
                          "spoiler inline-flex items-center justify-center px-2 py-0.5 rounded-full text-[10px] font-bold tracking-wider",
                          result === "pass"
                            ? "bg-[var(--color-gold)] text-black"
                            : "bg-[var(--color-surface)] text-[var(--color-text-muted)] border border-[var(--color-border-strong)]",
                        ]}
                        data-spoiler-level="result"
                      >
                        {result === "pass" ? "LC" : "NO"}
                      </span>
                    ) : <span class="text-[var(--color-text-subtle)]">—</span>}
                  </td>
                  {cells.map((cell, ji) => {
                    const titleParts: string[] = [judges[ji].data.name];
                    if (cell.first.comment) titleParts.push(`ファースト: ${cell.first.comment}`);
                    if (cell.final.comment) titleParts.push(`最終: ${cell.final.comment}`);
                    return (
                      <td class="px-1.5 py-2 text-center align-middle" title={titleParts.join(" · ")}>
                        <div class="inline-flex flex-col items-center gap-0.5">
                          <VoteChip vote={cell.first.vote} size="sm" round="first" judgeName={judges[ji].data.name} />
                          <VoteChip vote={cell.final.vote} size="sm" round="final" judgeName={judges[ji].data.name} />
                        </div>
                      </td>
                    );
                  })}
                </tr>
              );
            })}
          </tbody>
          {judgeStats.some((t) => t.recorded > 0) && (
            <tfoot class="border-t-2 border-[var(--color-border-strong)] bg-[var(--color-surface)] text-[var(--color-text-muted)]">
              <tr>
                <th scope="row" class="text-left font-medium px-3 py-2 whitespace-nowrap sticky left-0 z-10 bg-[var(--color-surface)]">
                  累計
                  <div class="text-[9px] text-[var(--color-text-subtle)] font-normal">最終</div>
                </th>
                <td class="px-3 py-2 text-[10px] text-[var(--color-text-subtle)] whitespace-nowrap sticky left-[60px] z-10 bg-[var(--color-surface)]">合格率（最終）</td>
                <td class="px-3 py-2 text-center text-[10px] whitespace-nowrap">
                  <span class="spoiler" data-spoiler-level="result">
                    <span class="text-[var(--color-gold)] font-bold tabular-nums">{overallPassRate ?? "—"}</span>
                    {overallPassRate !== null && <span class="text-[var(--color-text-subtle)]">%</span>}
                  </span>
                </td>
                {judgeStats.map((t) => (
                  <td class="px-1.5 py-2 text-center align-middle">
                    {t.recorded === 0 ? (
                      <span class="text-[10px] text-[var(--color-text-subtle)]">—</span>
                    ) : (
                      <div class="spoiler inline-flex flex-col items-center text-[10px] leading-tight" data-spoiler-level="vote">
                        <span class="text-[var(--color-gold)] font-bold tabular-nums">
                          {t.passRate ?? 0}%
                        </span>
                        <span class="text-[var(--color-text-subtle)] tabular-nums text-[9px]">
                          {t.lastCall}/{t.recorded}
                        </span>
                      </div>
                    )}
                  </td>
                ))}
              </tr>
            </tfoot>
          )}
        </table>
      </div>
    </section>
  </div>
</Layout>

<style>
  /* Sticky shadow on left columns for visual separation when scrolling */
  .lc-matrix th[scope="col"]:nth-child(2),
  .lc-matrix td:nth-child(2) {
    box-shadow: 1px 0 0 var(--color-border);
  }
</style>
