---
import { getCollection } from "astro:content";
import Layout from "../components/Layout.astro";
import EpisodeCard from "../components/EpisodeCard.astro";
import StatCard from "../components/StatCard.astro";
import DivergingBar from "../components/DivergingBar.astro";
import StructuredData from "../components/StructuredData.astro";
import { siteLink, absUrl } from "../lib/url";

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "LAST CALL 非公式ファンサイト",
  url: absUrl("/"),
  inLanguage: "ja",
  description:
    "YouTubeオーディション番組「LAST CALL（ラストコール）」の各回・出演者・投票結果をまとめる非公式ファンサイト。",
};

const episodes = (await getCollection("episodes")).sort(
  (a, b) => b.data.airedAt.getTime() - a.data.airedAt.getTime()
);
const cinderellas = await getCollection("cinderellas");
const judges = await getCollection("judges");

const latest = episodes[0];
const rest = episodes.slice(1);

// Aggregate stats across all final votes
const finalVotes = episodes.flatMap((ep) => ep.data.votes.filter((v) => v.round === "final"));
const totalPass = finalVotes.filter((v) => v.vote === "LAST CALL").length;
const totalFail = finalVotes.filter((v) => v.vote === "NOTHING" || v.vote === "NO CALL").length;

// Latest update date
const latestUpdate = latest
  ? latest.data.airedAt.toISOString().slice(0, 10).replace(/-/g, ".")
  : null;

// Editorial split: feature card + 2 small + remaining grid
const sub = rest.slice(0, 2);
const archive = rest.slice(2);
---

<Layout>
  <StructuredData slot="head" schema={websiteSchema} />
  {/* Hero — oversized editorial type */}
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-[-10%] left-1/2 -translate-x-1/2 w-[90%] h-[70%] rounded-full blur-[140px] opacity-40 bg-[var(--color-gold-deep)]"></div>
    </div>
    <div class="max-w-6xl mx-auto px-5 sm:px-8 pt-20 sm:pt-28 pb-16 sm:pb-24 relative">
      <div class="space-y-8 sm:space-y-10">
        <div class="space-y-3 sm:space-y-4">
          <p class="eyebrow">
            Unofficial Fan Archive
            <span class="mx-2 text-[var(--color-border-strong)]">·</span>
            {latestUpdate ? `Last update ${latestUpdate}` : "Since 2026"}
            <span class="mx-2 text-[var(--color-border-strong)]">·</span>
            {episodes.length} Episodes
          </p>
          <h1
            class="font-display-serif text-[var(--color-text)] leading-[0.9] tracking-tight"
            style="font-size: clamp(3.5rem, 12vw, 9rem);"
          >
            <span class="block">LAST</span>
            <span class="block text-[var(--color-gold)] italic">CALL</span>
          </h1>
        </div>
        <div class="max-w-2xl space-y-5">
          <p class="text-sm sm:text-base text-[var(--color-text-muted)] leading-[1.85]">
            YouTube 配信のキャバ嬢オーディション番組
            <a href="https://lastcall.jp/" target="_blank" rel="noopener" class="text-[var(--color-text)] underline decoration-[var(--color-border-strong)] hover:decoration-[var(--color-gold)]">LAST CALL</a>
            の各回・シンデレラ・14 名のレジェンドキャバ嬢による審査結果を、
            <span class="text-[var(--color-text)]">回ごと</span>・<span class="text-[var(--color-text)]">審査員ごと</span>に横断できる索引として整理。
          </p>
          <div class="flex flex-wrap gap-3 pt-1">
            <a
              href="#latest"
              class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-[var(--color-gold)] text-black text-sm font-semibold tracking-wide hover:bg-[var(--color-gold-bright)] transition"
            >
              最新回を見る
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
              </svg>
            </a>
            <a
              href={siteLink("/people/#matrix")}
              class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full border border-[var(--color-border-strong)] text-sm hover:border-[var(--color-gold)] hover:text-[var(--color-gold-bright)] transition"
            >
              審査マトリックスを開く
            </a>
          </div>
        </div>
      </div>
    </div>
    <div class="absolute bottom-0 left-0 right-0 hairline"></div>
  </section>

  <div class="max-w-6xl mx-auto px-5 sm:px-8 py-16 sm:py-20 space-y-20 sm:space-y-24">
    {/* Stats strip */}
    <section class="grid grid-cols-3 gap-3 sm:gap-5 -mt-4">
      <StatCard label="Episodes" value={episodes.length} sublabel="配信済み回数" />
      <StatCard label="Cinderellas" value={cinderellas.length} sublabel="登場した志願者" />
      <StatCard label="Judges" value={judges.length} sublabel="固定レジェンド" />
    </section>

    {/* Onboarding — 番組の仕組みとサイトの使い方（事実のみ） */}
    <section class="space-y-6">
      <h2 class="section-eyebrow">はじめに</h2>
      <div class="grid gap-4 sm:gap-5 md:grid-cols-2">
        <div class="card p-6 space-y-3">
          <p class="eyebrow">審査の仕組み</p>
          <p class="text-sm text-[var(--color-text-muted)] leading-[1.85]">
            各回 1 名のシンデレラ（志願者）に対し、固定の 14 名が審査します。判定は 2 ラウンド制で、
            番組前半の暫定判定<strong class="text-[var(--color-text)]">「ファーストコール」</strong>と、合否を確定する
            <strong class="text-[var(--color-text)]">「最終ジャッジ」</strong>に分かれます。
            このサイトの合格率・合否はすべて<strong class="text-[var(--color-text)]">最終ジャッジ</strong>の票で集計しています。
          </p>
          <div class="flex flex-wrap items-center gap-2 pt-1 text-[11px] text-[var(--color-text-subtle)]">
            <span class="px-2 py-0.5 rounded-full border border-[var(--color-border)] bg-[var(--color-surface)]">ファーストコール</span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            <span class="px-2 py-0.5 rounded-full border border-[var(--color-border-strong)] bg-[var(--color-surface)] text-[var(--color-text-muted)]">最終ジャッジ</span>
            <span class="text-[var(--color-border-strong)]">·</span>
            <span>票種: LAST CALL / NOTHING / NO CALL</span>
          </div>
        </div>
        <div class="card p-6 space-y-3">
          <p class="eyebrow">ネタバレ表示モード</p>
          <p class="text-sm text-[var(--color-text-muted)] leading-[1.85]">
            合否・票内訳・コメントは<strong class="text-[var(--color-text)]">既定で非表示</strong>です。
            画面右上のトグルで「全隠 / 結果伏 / 全表示」を切り替えられ、選択はブラウザに保存されます。
            個別のぼかし部分はタップ／クリックでその場だけ表示できます。
          </p>
          <div class="flex flex-wrap items-center gap-2 pt-1 text-[11px]">
            <span class="font-display tracking-[0.18em] font-semibold px-2 py-0.5 rounded-full bg-[var(--color-surface)] border border-[var(--color-border)] text-[var(--color-text)]">全隠</span>
            <span class="font-display tracking-[0.18em] font-semibold px-2 py-0.5 rounded-full bg-[var(--color-surface)] border border-[var(--color-border)] text-[var(--color-text)]">結果伏</span>
            <span class="font-display tracking-[0.18em] font-semibold px-2 py-0.5 rounded-full bg-[var(--color-gold)] text-black">全表示</span>
            <a href={siteLink("/about/")} class="ml-auto text-[var(--color-text-subtle)] underline decoration-[var(--color-border-strong)] hover:text-[var(--color-gold-bright)]">詳しく</a>
          </div>
        </div>
      </div>
    </section>

    {/* Latest episode — editorial pick */}
    {latest && (
      <section id="latest" class="space-y-6 scroll-mt-24">
        <div class="flex items-end justify-between gap-3">
          <h2 class="section-eyebrow">Latest Episode</h2>
          <span class="text-[10px] tracking-[0.24em] uppercase text-[var(--color-text-subtle)] tabular-nums">
            #{latest.data.id}
          </span>
        </div>
        <EpisodeCard episode={latest} variant="feature" />
      </section>
    )}

    {/* Recent sub picks (2-up) + archive grid below */}
    {sub.length > 0 && (
      <section class="space-y-6">
        <div class="flex items-end justify-between gap-3">
          <h2 class="section-eyebrow">Recently aired</h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 sm:gap-6">
          {sub.map((ep) => (
            <EpisodeCard episode={ep} />
          ))}
        </div>
      </section>
    )}

    {/* Overall verdict snapshot */}
    {totalPass + totalFail > 0 && (
      <section class="space-y-5">
        <h2 class="section-eyebrow">Overall verdict</h2>
        <div class="card p-6 sm:p-8 space-y-4">
          <p class="text-xs sm:text-sm text-[var(--color-text-muted)] leading-relaxed max-w-xl">
            全 <span class="text-[var(--color-text)]">{episodes.length}</span> 回の <span class="text-[var(--color-text)]">最終ジャッジ</span> を集計。LAST CALL（合格判定）と NOTHING / NO CALL（不合格判定）の総票数バランスです。
          </p>
          <DivergingBar
            pass={totalPass}
            fail={totalFail}
            label="Total final judgments"
            size="lg"
            spoilerLevel="result"
          />
        </div>
      </section>
    )}

    {/* Archive grid */}
    {archive.length > 0 && (
      <section id="episodes" class="space-y-6 scroll-mt-24">
        <div class="flex items-end justify-between gap-3">
          <h2 class="section-eyebrow">Archive</h2>
          <a
            href={siteLink("/people/#matrix")}
            class="text-[11px] text-[var(--color-text-muted)] hover:text-[var(--color-gold-bright)] transition tracking-wider inline-flex items-center gap-1"
          >
            審査マトリックスで横断
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
            </svg>
          </a>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 sm:gap-6">
          {archive.map((ep) => (
            <EpisodeCard episode={ep} />
          ))}
        </div>
      </section>
    )}

    {episodes.length === 0 && (
      <section class="rounded-lg border border-dashed border-[var(--color-border)] p-10 text-center text-[var(--color-text-muted)]">
        エピソードデータが未投入です。<code>src/content/episodes/</code> にJSONを追加してください。
      </section>
    )}
  </div>
</Layout>
