---
import { getCollection, getEntry } from "astro:content";
import Layout from "../../components/Layout.astro";
import YouTubeEmbed from "../../components/YouTubeEmbed.astro";
import VoteTable from "../../components/VoteTable.astro";
import SnsLinks from "../../components/SnsLinks.astro";
import { siteLink, youtubeUrl } from "../../lib/url";

export async function getStaticPaths() {
  const episodes = await getCollection("episodes");
  return episodes.map((episode) => ({
    params: { id: episode.data.id },
    props: { episode },
  }));
}

const { episode } = Astro.props;
const cinderella = await getEntry(episode.data.cinderella);
const dateLabel = episode.data.airedAt.toISOString().slice(0, 10);

// 前後回のナビゲーション
const allEpisodes = (await getCollection("episodes")).sort(
  (a, b) => a.data.airedAt.getTime() - b.data.airedAt.getTime()
);
const idx = allEpisodes.findIndex((e) => e.data.id === episode.data.id);
const prev = idx > 0 ? allEpisodes[idx - 1] : null;
const next = idx >= 0 && idx < allEpisodes.length - 1 ? allEpisodes[idx + 1] : null;
---

<Layout
  title={`#${episode.data.id} ${episode.data.title}`}
  description={episode.data.summary ?? episode.data.title}
>
  <article class="max-w-4xl mx-auto px-5 sm:px-8 py-12 sm:py-16 space-y-12">
    <header class="space-y-4">
      <div class="flex flex-wrap items-center gap-3">
        <p class="eyebrow">Episode #{episode.data.id}</p>
        {cinderella && (
          <span
            class:list={[
              "spoiler font-display tracking-[0.18em] text-[10px] font-semibold px-2.5 py-1 rounded-full",
              cinderella.data.result === "pass"
                ? "bg-[var(--color-gold)] text-black"
                : "bg-transparent text-[var(--color-text-subtle)] border border-[var(--color-border-strong)]",
            ]}
          >
            {cinderella.data.result === "pass" ? "LAST CALL · 合格" : "NOTHING · 不合格"}
          </span>
        )}
      </div>
      <h1 class="font-display-serif text-2xl sm:text-4xl leading-tight text-[var(--color-text)]">
        {episode.data.title}
      </h1>
      <div class="text-xs text-[var(--color-text-subtle)] tracking-wider">
        {dateLabel}
        <span class="mx-2 text-[var(--color-border-strong)]">/</span>
        <a
          href={youtubeUrl(episode.data.youtubeId)}
          target="_blank"
          rel="noopener"
          class="underline decoration-[var(--color-border-strong)] hover:text-[var(--color-gold-bright)] hover:decoration-[var(--color-gold)]"
        >
          YouTubeで見る
        </a>
      </div>
    </header>

    {episode.data.summary && (
      <p class="spoiler-block text-sm sm:text-base leading-relaxed text-[var(--color-text)]">
        {episode.data.summary}
      </p>
    )}

    <section class="space-y-4">
      <h2 class="section-eyebrow">Video</h2>
      <YouTubeEmbed videoId={episode.data.youtubeId} title={episode.data.title} />
    </section>

    {cinderella && (
      <section class="space-y-4">
        <h2 class="section-eyebrow">Cinderella</h2>
        <div class="card p-6 space-y-4">
          <div class="flex flex-wrap items-baseline justify-between gap-3">
            <h3 class="text-xl font-semibold">
              <a
                href={siteLink(`/cinderellas/${cinderella.id}/`)}
                class="hover:text-[var(--color-gold-bright)] transition"
              >
                {cinderella.data.name}
              </a>
              {cinderella.data.age && (
                <span class="text-sm text-[var(--color-text-muted)] ml-2">{cinderella.data.age}歳</span>
              )}
            </h3>
            <span
              class:list={[
                "spoiler px-2 py-0.5 rounded text-xs font-semibold tracking-wider",
                cinderella.data.result === "pass"
                  ? "bg-[var(--color-gold)] text-black"
                  : "bg-[var(--color-fail)] text-white",
              ]}
            >
              {cinderella.data.result === "pass" ? "合格" : "不合格"}
            </span>
          </div>
          {cinderella.data.background && (
            <p class="spoiler-block text-sm text-[var(--color-text-muted)] leading-relaxed">
              {cinderella.data.background}
            </p>
          )}
          <SnsLinks sns={cinderella.data.sns} size="sm" />
        </div>
      </section>
    )}

    <VoteTable votes={episode.data.votes} cinderellaResult={cinderella?.data.result} />

    {episode.data.sources.length > 0 && (
      <section class="space-y-3 pt-6 border-t border-[var(--color-border)]">
        <h2 class="section-eyebrow">Sources</h2>
        <ul class="text-sm space-y-1">
          {episode.data.sources.map((url) => (
            <li>
              <a
                href={url}
                target="_blank"
                rel="noopener nofollow"
                class="text-[var(--color-text-muted)] underline hover:text-[var(--color-gold-bright)] break-all"
              >
                {url}
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    <nav class="pt-6 border-t border-[var(--color-border)] grid grid-cols-1 sm:grid-cols-2 gap-3 text-sm">
      {prev ? (
        <a
          href={siteLink(`/episodes/${prev.data.id}/`)}
          class="group card p-4 sm:p-5 min-w-0"
        >
          <div class="text-[10px] tracking-[0.24em] uppercase text-[var(--color-text-subtle)] mb-1">← Prev · #{prev.data.id}</div>
          <div class="truncate group-hover:text-[var(--color-gold-bright)] transition">{prev.data.title}</div>
        </a>
      ) : <span class="hidden sm:block" />}
      {next ? (
        <a
          href={siteLink(`/episodes/${next.data.id}/`)}
          class="group card p-4 sm:p-5 min-w-0 sm:text-right"
        >
          <div class="text-[10px] tracking-[0.24em] uppercase text-[var(--color-text-subtle)] mb-1">Next · #{next.data.id} →</div>
          <div class="truncate group-hover:text-[var(--color-gold-bright)] transition">{next.data.title}</div>
        </a>
      ) : <span class="hidden sm:block" />}
    </nav>
  </article>
</Layout>
