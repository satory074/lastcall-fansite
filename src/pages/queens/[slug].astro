---
// LAST CALL クイーン個別プロフィール。本体は show 対応の共有コンポーネント QueenProfile に集約。
import QueenProfile from "../../components/QueenProfile.astro";
import { rosterForShow } from "../../lib/show";

export async function getStaticPaths() {
  const queens = await rosterForShow("lastcall");
  return queens.map((j) => ({
    params: { slug: j.id },
    props: { queen: j },
  }));
}

const { queen } = Astro.props;
---

<QueenProfile queen={queen} />
