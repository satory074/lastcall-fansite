---
import "../styles/globals.css";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = "LAST CALL 非公式ファンサイト",
  description = "YouTubeオーディション番組「LAST CALL（ラストコール）」の各回・出演者・投票結果をまとめる非公式ファンサイトです。",
  ogImage,
} = Astro.props;

const fullTitle =
  title === "LAST CALL 非公式ファンサイト"
    ? title
    : `${title} | LAST CALL 非公式ファンサイト`;

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = ogImage ? new URL(ogImage, Astro.site).toString() : undefined;

const nav = [
  { href: "/people/", label: "出演者・審査一覧" },
  { href: "/about/", label: "このサイトについて" },
];

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const linkOf = (href: string) => `${base}${href}`;
const currentPath = Astro.url.pathname.replace(base, "") || "/";
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="robots" content="index,follow" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Noto+Sans+JP:wght@400;500;700&family=Noto+Serif+JP:wght@500;700;900&display=swap"
    />
    <script is:inline>
      // FOUC回避: html へ 3 状態スポイラーモードを反映
      (function () {
        try {
          var v = localStorage.getItem("lc-spoilers");
          var cls;
          if (v === "shown" || v === "show") cls = "spoilers-shown";
          else if (v === "results-only") cls = "spoilers-results-only";
          else cls = "spoilers-hidden";
          document.documentElement.classList.add(cls);
        } catch (_) {
          document.documentElement.classList.add("spoilers-hidden");
        }
      })();
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <a href="#lc-main" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-[60] focus:px-3 focus:py-2 focus:rounded focus:bg-[var(--color-gold)] focus:text-black focus:text-xs focus:font-semibold">
      メインコンテンツへスキップ
    </a>
    <header class="border-b border-[var(--color-border)] sticky top-0 z-50 backdrop-blur-xl bg-[color-mix(in_oklab,var(--color-bg)_75%,transparent)]">
      <div class="max-w-6xl mx-auto px-5 sm:px-8 py-4 flex items-center justify-between gap-3 sm:gap-4">
        <a href={linkOf("/")} class="flex items-center gap-3 group shrink-0">
          <span class="font-display tracking-[0.32em] text-base sm:text-lg font-bold text-[var(--color-text)] group-hover:text-[var(--color-gold-bright)] transition">
            LAST<span class="text-[var(--color-gold)]">·</span>CALL
          </span>
          <span class="hidden sm:inline text-[10px] tracking-[0.2em] uppercase text-[var(--color-text-subtle)] px-2 py-0.5 border border-[var(--color-border)] rounded-full">
            Unofficial Archive
          </span>
        </a>
        <div class="flex items-center gap-3 sm:gap-5">
          <nav class="hidden md:flex items-center gap-6 text-[13px]">
            {nav.map((item) => {
              const active = item.href === "/" ? currentPath === "/" : currentPath.startsWith(item.href);
              return (
                <a
                  href={linkOf(item.href)}
                  class:list={[
                    "transition relative py-1",
                    active
                      ? "text-[var(--color-gold)]"
                      : "text-[var(--color-text-muted)] hover:text-[var(--color-text)]",
                    active && "after:absolute after:bottom-0 after:left-0 after:right-0 after:h-px after:bg-[var(--color-gold)]",
                  ]}
                >
                  {item.label}
                </a>
              );
            })}
          </nav>
          {/* Spoiler 3-state segmented control */}
          <div
            id="lc-spoiler-toggle"
            class="inline-flex items-stretch rounded-full border border-[var(--color-border)] bg-[color-mix(in_oklab,var(--color-bg)_60%,transparent)] p-0.5 text-[10px] sm:text-[11px]"
            role="group"
            aria-label="ネタバレ表示モード"
          >
            <button type="button" data-mode="hidden" class="lc-seg px-2 sm:px-3 py-1.5 rounded-full transition tracking-wider" title="全て隠す（合否・票・コメントを全部ぼかす）">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="inline-block align-text-bottom">
                <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/>
              </svg>
              <span class="hidden sm:inline ml-1">全隠</span>
            </button>
            <button type="button" data-mode="results-only" class="lc-seg px-2 sm:px-3 py-1.5 rounded-full transition tracking-wider" title="結果のみ隠す（合否は伏せ、票・コメントは表示）">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="inline-block align-text-bottom">
                <path d="M2 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="13" cy="12" r="2.5" fill="currentColor" stroke="none"/>
              </svg>
              <span class="hidden sm:inline ml-1">結果伏</span>
            </button>
            <button type="button" data-mode="shown" class="lc-seg px-2 sm:px-3 py-1.5 rounded-full transition tracking-wider" title="全て表示（ネタバレ含む）">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="inline-block align-text-bottom">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
              </svg>
              <span class="hidden sm:inline ml-1">全表示</span>
            </button>
          </div>
        </div>
      </div>
      <nav class="md:hidden border-t border-[var(--color-border)]">
        <div class="max-w-6xl mx-auto px-4 py-2 flex gap-4 overflow-x-auto text-sm">
          {nav.map((item) => {
            const active = item.href === "/" ? currentPath === "/" : currentPath.startsWith(item.href);
            return (
              <a
                href={linkOf(item.href)}
                class:list={[
                  "whitespace-nowrap transition",
                  active ? "text-[var(--color-gold)]" : "text-[var(--color-text-muted)]",
                ]}
              >
                {item.label}
              </a>
            );
          })}
        </div>
      </nav>
    </header>

    <main id="lc-main" class="flex-1">
      <slot />
    </main>

    <footer class="mt-24 border-t border-[var(--color-border)]">
      <div class="max-w-6xl mx-auto px-5 sm:px-8 py-10 text-xs text-[var(--color-text-subtle)] grid gap-6 md:grid-cols-3">
        <div class="md:col-span-2 space-y-2">
          <p class="font-display tracking-[0.32em] text-[var(--color-text-muted)] uppercase text-[10px]">Disclaimer</p>
          <p class="text-[var(--color-text-muted)] leading-relaxed">
            本サイトは <a href="https://lastcall.jp/" class="underline decoration-[var(--color-border-strong)] hover:text-[var(--color-gold-bright)] hover:decoration-[var(--color-gold)]" target="_blank" rel="noopener">LAST CALL（ラストコール）</a>
            の非公式ファンサイトです。番組・出演者・運営とは無関係。画像・動画は公式YouTube（<a href="https://www.youtube.com/@LASTCALL_OFFICIAL" class="underline decoration-[var(--color-border-strong)] hover:text-[var(--color-gold-bright)] hover:decoration-[var(--color-gold)]" target="_blank" rel="noopener">@LASTCALL_OFFICIAL</a>）の埋め込み・リンクのみ。
          </p>
        </div>
        <div class="space-y-2">
          <p class="font-display tracking-[0.32em] text-[var(--color-text-muted)] uppercase text-[10px]">Contact</p>
          <p>
            修正・削除依頼は <a href={linkOf("/about/")} class="underline decoration-[var(--color-border-strong)] hover:text-[var(--color-gold-bright)] hover:decoration-[var(--color-gold)]">このサイトについて</a> へ。
          </p>
        </div>
      </div>
    </footer>

    <script>
      type Mode = "hidden" | "results-only" | "shown";
      const root = document.documentElement;
      const group = document.getElementById("lc-spoiler-toggle");
      const buttons = Array.from(group?.querySelectorAll<HTMLButtonElement>("button.lc-seg") ?? []);
      const CLASSES: Record<Mode, string> = {
        hidden: "spoilers-hidden",
        "results-only": "spoilers-results-only",
        shown: "spoilers-shown",
      };

      function readMode(): Mode {
        try {
          const v = localStorage.getItem("lc-spoilers");
          if (v === "shown" || v === "show") return "shown";
          if (v === "results-only") return "results-only";
        } catch (_) {}
        return "hidden";
      }

      function applyMode(mode: Mode) {
        for (const m of Object.values(CLASSES)) root.classList.remove(m);
        root.classList.add(CLASSES[mode]);
        // legacy alias for any leftover .show-spoilers references
        root.classList.toggle("show-spoilers", mode === "shown");
        for (const b of buttons) {
          const active = b.dataset.mode === mode;
          b.setAttribute("aria-pressed", String(active));
          b.classList.toggle("bg-[var(--color-gold)]", active);
          b.classList.toggle("text-black", active);
          b.classList.toggle("font-semibold", active);
          b.classList.toggle("text-[var(--color-text-muted)]", !active);
        }
        try {
          localStorage.setItem("lc-spoilers", mode);
        } catch (_) {}
      }

      applyMode(readMode());

      for (const b of buttons) {
        b.addEventListener("click", () => {
          applyMode((b.dataset.mode as Mode) ?? "hidden");
        });
      }

      // 個別の .spoiler クリックで一時的に表示（全表示モードのときは何もしない）
      document.addEventListener("click", (ev) => {
        if (root.classList.contains("spoilers-shown")) return;
        const target = ev.target as HTMLElement | null;
        const el = target?.closest<HTMLElement>(".spoiler, .spoiler-block");
        if (!el) return;
        // results-only モードのとき、result 以外のスポイラーは元々ぼかされていない → reveal 不要
        if (root.classList.contains("spoilers-results-only")) {
          const lv = el.dataset.spoilerLevel;
          if (lv && lv !== "result") return;
        }
        // 親リンクと競合する場合はナビゲーションを止める
        if (el.closest("a") && !el.classList.contains("spoiler-revealed")) {
          ev.preventDefault();
          ev.stopPropagation();
        }
        el.classList.add("spoiler-revealed");
      });
    </script>
  </body>
</html>
