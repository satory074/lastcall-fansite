---
import "../styles/globals.css";
import { SHOWS, SHOW_META, showMeta, type Show } from "../lib/show";

interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  breadcrumbs?: Crumb[];
  /** このページが属する番組。ヘッダー配色（data-show）・ブランド・ナビを切り替える。既定 lastcall。 */
  show?: Show;
}

const {
  title,
  description,
  ogImage = "/lastcall-fansite/og-default.png",
  breadcrumbs,
  show = "lastcall",
} = Astro.props;

const meta = showMeta(show);
const siteName = `${meta.brand} 非公式ファンサイト`;
const resolvedTitle = title ?? siteName;
const resolvedDescription = description ?? meta.description;
const fullTitle =
  resolvedTitle === siteName ? resolvedTitle : `${resolvedTitle} | ${siteName}`;

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = new URL(ogImage, Astro.site).toString();

// Cloudflare Web Analytics — Cookie 不要のプライバシー配慮解析。PUBLIC_CF_BEACON_TOKEN が
// あればビーコンを出力、未設定なら非出力（graceful）。トークンは公開値なのでリポジトリ変数で駆動。
const cfBeaconToken = import.meta.env.PUBLIC_CF_BEACON_TOKEN;

const nav = [
  { href: `${meta.basePath}/people/`, label: "出演者・審査一覧" },
  { href: "/about/", label: "このサイトについて" },
];

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const linkOf = (href: string) => `${base}${href}`;
const currentPath = Astro.url.pathname.replace(base, "") || "/";

// パンくず: 先頭に「ホーム」を補い、視覚表示と BreadcrumbList JSON-LD を生成。
const crumbs: Crumb[] = breadcrumbs
  ? [{ label: "ホーム", href: linkOf(`${meta.basePath}/`) }, ...breadcrumbs]
  : [];
const breadcrumbSchema =
  crumbs.length > 0
    ? {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        itemListElement: crumbs.map((c, i) => ({
          "@type": "ListItem",
          position: i + 1,
          name: c.label,
          ...(c.href ? { item: new URL(c.href, Astro.site).toString() } : {}),
        })),
      }
    : null;
---

<!doctype html>
<html lang="ja" data-base={base} data-show={show}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={resolvedDescription} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href={linkOf("/favicon.svg")} type="image/svg+xml" />
    <link rel="apple-touch-icon" href={linkOf("/favicon.svg")} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="LAST CALL / HOSTCALL 非公式アーカイブ — 新着エピソード"
      href={linkOf("/rss.xml")}
    />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={resolvedDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="robots" content="index,follow" />
    {breadcrumbSchema && (
      <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />
    )}
    <slot name="head" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Noto+Sans+JP:wght@400;500;700&family=Noto+Serif+JP:wght@500;700;900&display=swap"
    />
    <script is:inline>
      // FOUC回避: html へ 3 状態スポイラーモードを反映
      (function () {
        try {
          var v = localStorage.getItem("lc-spoilers");
          var cls;
          if (v === "shown" || v === "show") cls = "spoilers-shown";
          else if (v === "results-only") cls = "spoilers-results-only";
          else cls = "spoilers-hidden";
          document.documentElement.classList.add(cls);
        } catch (_) {
          document.documentElement.classList.add("spoilers-hidden");
        }
      })();
    </script>
    {
      cfBeaconToken && (
        <script
          is:inline
          defer
          src="https://static.cloudflareinsights.com/beacon.min.js"
          data-cf-beacon={JSON.stringify({ token: cfBeaconToken })}
        />
      )
    }
  </head>
  <body class="min-h-screen flex flex-col">
    <a href="#lc-main" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-[60] focus:px-3 focus:py-2 focus:rounded focus:bg-[var(--color-gold)] focus:text-black focus:text-xs focus:font-semibold">
      メインコンテンツへスキップ
    </a>
    <header class="border-b border-[var(--color-border)] sticky top-0 z-50 backdrop-blur-xl bg-[color-mix(in_oklab,var(--color-bg)_75%,transparent)]">
      <div class="max-w-6xl mx-auto px-5 sm:px-8 py-4 flex items-center justify-between gap-3 sm:gap-4">
        <a href={linkOf(`${meta.basePath}/`)} class="flex items-center gap-3 group shrink-0">
          <span class="font-display tracking-[0.32em] text-base sm:text-lg font-bold text-[var(--color-text)] group-hover:text-[var(--color-gold-bright)] transition">
            {meta.brandParts[0]}<span class="text-[var(--color-gold)]">·</span>{meta.brandParts[1]}
          </span>
          <span class="hidden sm:inline text-[10px] tracking-[0.2em] uppercase text-[var(--color-text-subtle)] px-2 py-0.5 border border-[var(--color-border)] rounded-full">
            Unofficial Archive
          </span>
        </a>
        <div class="flex items-center gap-3 sm:gap-5 relative">
          <nav class="hidden md:flex items-center gap-6 text-[13px]">
            {nav.map((item) => {
              const active = item.href === "/" ? currentPath === "/" : currentPath.startsWith(item.href);
              return (
                <a
                  href={linkOf(item.href)}
                  class:list={[
                    "transition relative py-1",
                    active
                      ? "text-[var(--color-gold)]"
                      : "text-[var(--color-text-muted)] hover:text-[var(--color-text)]",
                    active && "after:absolute after:bottom-0 after:left-0 after:right-0 after:h-px after:bg-[var(--color-gold)]",
                  ]}
                >
                  {item.label}
                </a>
              );
            })}
          </nav>
          {/* 番組スイッチャー（デスクトップ）— 相手番組ホームへの実リンク。SSR で配色（data-show）が確定 */}
          <div
            class="hidden md:inline-flex items-stretch rounded-full border border-[var(--color-border)] bg-[color-mix(in_oklab,var(--color-bg)_60%,transparent)] p-0.5 text-[11px]"
            role="group"
            aria-label="番組を切り替え"
          >
            {SHOWS.map((s) => {
              const active = s === show;
              return (
                <a
                  href={linkOf(`${SHOW_META[s].basePath}/`)}
                  aria-current={active ? "page" : undefined}
                  class:list={[
                    "px-3 py-1.5 rounded-full tracking-wider transition whitespace-nowrap",
                    active
                      ? "bg-[var(--color-gold)] text-black font-semibold"
                      : "text-[var(--color-text-muted)] hover:text-[var(--color-text)]",
                  ]}
                >
                  {SHOW_META[s].brand}
                </a>
              );
            })}
          </div>
          {/* グローバル検索 */}
          <button
            type="button"
            id="lc-search-open"
            class="inline-flex items-center gap-1.5 rounded-full border border-[var(--color-border)] bg-[color-mix(in_oklab,var(--color-bg)_60%,transparent)] px-2.5 sm:px-3 py-1.5 text-[var(--color-text-muted)] hover:text-[var(--color-text)] hover:border-[var(--color-border-strong)] transition"
            aria-label="サイト内を検索"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <span class="hidden sm:inline text-[11px] tracking-wider">検索</span>
          </button>
          {/* Spoiler 3-state segmented control */}
          <div
            id="lc-spoiler-toggle"
            class="inline-flex items-stretch rounded-full border border-[var(--color-border)] bg-[color-mix(in_oklab,var(--color-bg)_60%,transparent)] p-0.5 text-[10px] sm:text-[11px]"
            role="group"
            aria-label="ネタバレ表示モード"
          >
            <button type="button" data-mode="hidden" class="lc-seg px-2 sm:px-3 py-1.5 rounded-full transition tracking-wider" title="全て隠す（合否・票・コメントを全部ぼかす）">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="inline-block align-text-bottom">
                <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/>
              </svg>
              <span class="hidden sm:inline ml-1">全隠</span>
            </button>
            <button type="button" data-mode="results-only" class="lc-seg px-2 sm:px-3 py-1.5 rounded-full transition tracking-wider" title="結果のみ隠す（合否は伏せ、票・コメントは表示）">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="inline-block align-text-bottom">
                <path d="M2 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="13" cy="12" r="2.5" fill="currentColor" stroke="none"/>
              </svg>
              <span class="hidden sm:inline ml-1">結果伏</span>
            </button>
            <button type="button" data-mode="shown" class="lc-seg px-2 sm:px-3 py-1.5 rounded-full transition tracking-wider" title="全て表示（ネタバレ含む）">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="inline-block align-text-bottom">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
              </svg>
              <span class="hidden sm:inline ml-1">全表示</span>
            </button>
          </div>
          {/* 初回訪問時のみ表示するネタバレモード案内（JSで制御） */}
          <div
            id="lc-spoiler-hint"
            hidden
            class="absolute right-0 top-[calc(100%+0.6rem)] z-[55] w-60 rounded-lg border border-[var(--color-gold-deep)] bg-[var(--color-surface)] px-3.5 py-3 text-left shadow-[0_12px_36px_-10px_rgba(0,0,0,0.6)]"
            role="status"
          >
            <span class="absolute -top-1.5 right-8 h-3 w-3 rotate-45 border-l border-t border-[var(--color-gold-deep)] bg-[var(--color-surface)]"></span>
            <p class="text-[12px] leading-relaxed text-[var(--color-text-muted)]">
              合否や投票結果は<strong class="text-[var(--color-text)]">既定で非表示</strong>です。ここで表示モードを切り替えられます。
            </p>
            <button type="button" id="lc-spoiler-hint-close" class="mt-2 text-[11px] font-semibold text-[var(--color-gold)] hover:text-[var(--color-gold-bright)]">
              わかった
            </button>
          </div>
        </div>
      </div>
      <nav class="md:hidden border-t border-[var(--color-border)]">
        <div class="max-w-6xl mx-auto px-4 py-2 flex items-center gap-3 overflow-x-auto text-sm">
          {/* 番組スイッチャー（モバイル） */}
          <div
            class="inline-flex items-stretch rounded-full border border-[var(--color-border)] bg-[var(--color-surface)] p-0.5 text-[10px] shrink-0"
            role="group"
            aria-label="番組を切り替え"
          >
            {SHOWS.map((s) => {
              const active = s === show;
              return (
                <a
                  href={linkOf(`${SHOW_META[s].basePath}/`)}
                  aria-current={active ? "page" : undefined}
                  class:list={[
                    "px-2.5 py-1 rounded-full tracking-wider transition whitespace-nowrap",
                    active
                      ? "bg-[var(--color-gold)] text-black font-semibold"
                      : "text-[var(--color-text-muted)]",
                  ]}
                >
                  {SHOW_META[s].brand}
                </a>
              );
            })}
          </div>
          <span class="w-px self-stretch bg-[var(--color-border)] shrink-0" aria-hidden="true"></span>
          {nav.map((item) => {
            const active = item.href === "/" ? currentPath === "/" : currentPath.startsWith(item.href);
            return (
              <a
                href={linkOf(item.href)}
                class:list={[
                  "whitespace-nowrap transition",
                  active ? "text-[var(--color-gold)]" : "text-[var(--color-text-muted)]",
                ]}
              >
                {item.label}
              </a>
            );
          })}
        </div>
      </nav>
    </header>

    <noscript>
      <div class="bg-[var(--color-surface)] border-b border-[var(--color-border)] text-[12px] text-[var(--color-text-muted)] px-4 py-2 text-center leading-relaxed">
        JavaScript が無効です。ネタバレ防止モードは「全隠し」固定になります。モード切替や個別解除を行うには JavaScript を有効にしてください。
      </div>
    </noscript>

    {crumbs.length > 0 && (
      <nav aria-label="パンくずリスト" class="border-b border-[var(--color-border)] bg-[color-mix(in_oklab,var(--color-bg)_85%,transparent)]">
        <ol class="max-w-6xl mx-auto px-5 sm:px-8 py-2.5 flex flex-wrap items-center gap-x-2 gap-y-1 text-[11px] sm:text-xs text-[var(--color-text-subtle)]">
          {crumbs.map((c, i) => (
            <li class="flex items-center gap-2">
              {i > 0 && <span aria-hidden="true" class="text-[var(--color-border-strong)]">/</span>}
              {c.href && i < crumbs.length - 1 ? (
                <a href={c.href} class="hover:text-[var(--color-gold-bright)] transition truncate max-w-[12rem]">{c.label}</a>
              ) : (
                <span aria-current="page" class="text-[var(--color-text-muted)] truncate max-w-[14rem]">{c.label}</span>
              )}
            </li>
          ))}
        </ol>
      </nav>
    )}

    {/* 検索オーバーレイ（JSで開閉） */}
    <div id="lc-search" hidden class="fixed inset-0 z-[70] flex items-start justify-center px-4 pt-[12vh]">
      <div id="lc-search-backdrop" class="absolute inset-0 bg-[color-mix(in_oklab,var(--color-bg)_70%,transparent)] backdrop-blur-sm"></div>
      <div role="dialog" aria-modal="true" aria-label="サイト内検索" class="relative w-full max-w-lg rounded-2xl border border-[var(--color-border-strong)] bg-[var(--color-card)] shadow-[0_24px_64px_-16px_rgba(0,0,0,0.7)] overflow-hidden">
        <div class="flex items-center gap-2.5 px-4 py-3 border-b border-[var(--color-border)]">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="text-[var(--color-text-subtle)]"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <input
            id="lc-search-input"
            type="search"
            autocomplete="off"
            placeholder="回・出演者・審査員を検索…"
            class="flex-1 bg-transparent text-sm text-[var(--color-text)] placeholder:text-[var(--color-text-subtle)] focus:outline-none"
          />
          <kbd class="hidden sm:block text-[10px] text-[var(--color-text-subtle)] border border-[var(--color-border)] rounded px-1.5 py-0.5">Esc</kbd>
        </div>
        <ul id="lc-search-results" class="max-h-[55vh] overflow-y-auto py-1.5"></ul>
        <p id="lc-search-empty" hidden class="px-4 py-6 text-center text-xs text-[var(--color-text-subtle)]">該当する項目がありません。</p>
      </div>
    </div>

    <main id="lc-main" class="flex-1">
      <slot />
    </main>

    <footer class="mt-24 border-t border-[var(--color-border)]">
      <div class="max-w-6xl mx-auto px-5 sm:px-8 py-10 text-xs text-[var(--color-text-subtle)] grid gap-6 md:grid-cols-3">
        <div class="md:col-span-2 space-y-2">
          <p class="font-display tracking-[0.32em] text-[var(--color-text-muted)] uppercase text-[10px]">Disclaimer</p>
          <p class="text-[var(--color-text-muted)] leading-relaxed">
            本サイトは <a href="https://lastcall.jp/" class="underline decoration-[var(--color-border-strong)] hover:text-[var(--color-gold-bright)] hover:decoration-[var(--color-gold)]" target="_blank" rel="noopener">LAST CALL（ラストコール）</a>
            および姉妹番組 <a href="https://lastcall.jp/" class="underline decoration-[var(--color-border-strong)] hover:text-[var(--color-gold-bright)] hover:decoration-[var(--color-gold)]" target="_blank" rel="noopener">HOSTCALL（ホストコール）</a>
            の非公式ファンサイトです。番組・出演者・運営とは無関係。画像・動画は公式YouTube（<a href="https://www.youtube.com/@LASTCALL_OFFICIAL" class="underline decoration-[var(--color-border-strong)] hover:text-[var(--color-gold-bright)] hover:decoration-[var(--color-gold)]" target="_blank" rel="noopener">@LASTCALL_OFFICIAL</a>）の埋め込み・リンクのみ。
          </p>
        </div>
        <div class="space-y-2">
          <p class="font-display tracking-[0.32em] text-[var(--color-text-muted)] uppercase text-[10px]">Contact</p>
          <p>
            修正・削除依頼は <a href={linkOf("/about/")} class="underline decoration-[var(--color-border-strong)] hover:text-[var(--color-gold-bright)] hover:decoration-[var(--color-gold)]">このサイトについて</a> へ。
          </p>
        </div>
      </div>
    </footer>

    <script>
      type Mode = "hidden" | "results-only" | "shown";
      const root = document.documentElement;
      const group = document.getElementById("lc-spoiler-toggle");
      const buttons = Array.from(group?.querySelectorAll<HTMLButtonElement>("button.lc-seg") ?? []);
      const CLASSES: Record<Mode, string> = {
        hidden: "spoilers-hidden",
        "results-only": "spoilers-results-only",
        shown: "spoilers-shown",
      };

      function readMode(): Mode {
        try {
          const v = localStorage.getItem("lc-spoilers");
          if (v === "shown" || v === "show") return "shown";
          if (v === "results-only") return "results-only";
        } catch (_) {}
        return "hidden";
      }

      // payload を元に DOM へ本値を書き戻し、.lc-revealed を付与
      function hydrateElement(el: HTMLElement) {
        if (el.classList.contains("lc-revealed")) return;
        const raw = el.getAttribute("data-spoiler-payload");
        if (!raw) {
          el.classList.add("lc-revealed");
          return;
        }
        let p: Record<string, any>;
        try { p = JSON.parse(raw); } catch (_) { return; }

        const occ = el.dataset.occlusion;
        if (occ === "chip") {
          if (typeof p.cls === "string") el.className = (el.className + " " + p.cls).trim();
          if (typeof p.label === "string") el.textContent = p.label;
          if (typeof p.aria === "string") {
            el.setAttribute("aria-label", p.aria);
            el.setAttribute("title", p.aria);
          }
          if (typeof p.vote === "string") el.setAttribute("data-vote", p.vote);
        } else if (occ === "bar") {
          const failEl = el.querySelector<HTMLElement>("[data-bar=fail]");
          const passEl = el.querySelector<HTMLElement>("[data-bar=pass]");
          if (failEl && typeof p.failPct === "number") failEl.style.width = p.failPct + "%";
          if (passEl && typeof p.passPct === "number") passEl.style.width = p.passPct + "%";
          if (typeof p.aria === "string") el.setAttribute("aria-label", p.aria);
        } else {
          // text / block: 子要素 (.lc-payload-content) のテキストを書き戻す
          const slot = el.querySelector<HTMLElement>(".lc-payload-content");
          if (slot && typeof p.html === "string") slot.innerHTML = p.html;
          else if (slot && typeof p.text === "string") slot.textContent = p.text;
          else if (typeof p.text === "string") el.textContent = p.text;
          if (typeof p.aria === "string") el.setAttribute("aria-label", p.aria);
        }
        el.classList.add("lc-revealed");
      }

      function applyMode(mode: Mode) {
        const prev = (Object.entries(CLASSES) as Array<[Mode, string]>).find(([_, c]) => root.classList.contains(c))?.[0] ?? "hidden";
        for (const m of Object.values(CLASSES)) root.classList.remove(m);
        root.classList.add(CLASSES[mode]);
        root.classList.toggle("show-spoilers", mode === "shown");
        for (const b of buttons) {
          const active = b.dataset.mode === mode;
          b.setAttribute("aria-pressed", String(active));
          b.classList.toggle("bg-[var(--color-gold)]", active);
          b.classList.toggle("text-black", active);
          b.classList.toggle("font-semibold", active);
          b.classList.toggle("text-[var(--color-text-muted)]", !active);
        }
        try { localStorage.setItem("lc-spoilers", mode); } catch (_) {}

        // hydrate: モードに応じて該当要素を本値で復元。
        // 一度 hydrate された要素は className を直接変更しているため、
        // 「より隠す方向」への切替 (例: shown → hidden) は location.reload() で安全リセット。
        const willHideMore =
          (prev === "shown" && mode !== "shown") ||
          (prev === "results-only" && mode === "hidden");
        if (willHideMore && document.querySelector(".lc-occluded.lc-revealed")) {
          location.reload();
          return;
        }
        const all = document.querySelectorAll<HTMLElement>(".lc-occluded:not(.lc-revealed)");
        for (const el of all) {
          const lv = (el.dataset.spoilerLevel ?? "vote") as "result" | "vote" | "comment";
          const reveal =
            mode === "shown" ||
            (mode === "results-only" && lv !== "result");
          if (reveal) hydrateElement(el);
        }
      }

      applyMode(readMode());

      for (const b of buttons) {
        b.addEventListener("click", () => {
          applyMode((b.dataset.mode as Mode) ?? "hidden");
        });
      }

      // 初回訪問時のみ、ネタバレモードの案内を一度だけ表示する。
      (function initSpoilerHint() {
        const hint = document.getElementById("lc-spoiler-hint");
        if (!hint) return;
        let firstVisit = false;
        try {
          firstVisit =
            localStorage.getItem("lc-spoilers") === null &&
            localStorage.getItem("lc-spoiler-hint-seen") === null;
        } catch (_) {}
        if (!firstVisit) return;

        const dismiss = () => {
          hint.hidden = true;
          try { localStorage.setItem("lc-spoiler-hint-seen", "1"); } catch (_) {}
        };
        hint.hidden = false;
        document
          .getElementById("lc-spoiler-hint-close")
          ?.addEventListener("click", dismiss);
        // モードを切り替えたら役目を終えるので閉じる
        for (const b of buttons) b.addEventListener("click", dismiss, { once: true });
      })();

      // 個別の occlusion 要素クリックで一時的に表示
      document.addEventListener("click", (ev) => {
        if (root.classList.contains("spoilers-shown")) return;
        const target = ev.target as HTMLElement | null;
        const el = target?.closest<HTMLElement>(".lc-occluded:not(.lc-revealed)");
        if (!el) return;
        // results-only モード: result 以外は既に hydrate 済み
        if (root.classList.contains("spoilers-results-only")) {
          const lv = el.dataset.spoilerLevel ?? "vote";
          if (lv !== "result") return;
        }
        // 親リンクのナビゲーションを抑止
        if (el.closest("a")) {
          ev.preventDefault();
          ev.stopPropagation();
        }
        hydrateElement(el);
      });

      // 旧 .spoiler / .spoiler-block 要素の互換クリック解除 (alias)
      document.addEventListener("click", (ev) => {
        if (root.classList.contains("spoilers-shown")) return;
        const target = ev.target as HTMLElement | null;
        const el = target?.closest<HTMLElement>(".spoiler:not(.lc-occluded):not(.spoiler-revealed), .spoiler-block:not(.lc-occluded):not(.spoiler-revealed)");
        if (!el) return;
        if (root.classList.contains("spoilers-results-only")) {
          const lv = el.dataset.spoilerLevel;
          if (lv && lv !== "result") return;
        }
        if (el.closest("a")) {
          ev.preventDefault();
          ev.stopPropagation();
        }
        el.classList.add("spoiler-revealed");
      });
    </script>

    <script>
      // グローバル検索: ビルド時生成の /search-index.json を初回オープン時に取得し、
      // 名前・回・属性の部分一致で絞り込む。合否などのスポイラーは索引に含まれない。
      type SearchItem = { type: string; typeLabel?: string; show?: string; label: string; sub: string; url: string; terms: string };
      const overlay = document.getElementById("lc-search");
      const openBtn = document.getElementById("lc-search-open");
      const input = document.getElementById("lc-search-input") as HTMLInputElement | null;
      const list = document.getElementById("lc-search-results");
      const empty = document.getElementById("lc-search-empty");
      const backdrop = document.getElementById("lc-search-backdrop");

      if (overlay && openBtn && input && list && empty) {
        const TYPE_LABEL: Record<string, string> = {
          episode: "回",
          cinderella: "シンデレラ",
          queen: "クイーン",
        };
        let index: SearchItem[] | null = null;
        let loading = false;
        const base = document.documentElement.getAttribute("data-base") ?? "";

        async function ensureIndex() {
          if (index || loading) return;
          loading = true;
          try {
            const res = await fetch(base + "/search-index.json");
            index = (await res.json()) as SearchItem[];
          } catch (_) {
            index = [];
          }
          loading = false;
        }

        function render(q: string) {
          if (!index) return;
          const query = q.trim().toLowerCase();
          const matches = query
            ? index.filter((it) => it.terms.includes(query)).slice(0, 24)
            : [];
          list!.innerHTML = matches
            .map(
              (m) =>
                `<li><a href="${m.url}" class="flex items-center gap-3 px-4 py-2.5 hover:bg-[color-mix(in_oklab,var(--color-gold)_8%,transparent)] transition">
                  <span class="shrink-0 text-[9px] tracking-wider uppercase text-[var(--color-text-subtle)] border border-[var(--color-border)] rounded px-1.5 py-0.5">${m.typeLabel ?? TYPE_LABEL[m.type] ?? m.type}</span>
                  <span class="min-w-0"><span class="block text-sm text-[var(--color-text)] truncate">${m.label}</span><span class="block text-[11px] text-[var(--color-text-subtle)] truncate">${m.sub}</span></span>
                </a></li>`
            )
            .join("");
          empty!.hidden = !(query && matches.length === 0);
        }

        async function open() {
          overlay!.hidden = false;
          document.body.style.overflow = "hidden";
          await ensureIndex();
          input!.value = "";
          render("");
          input!.focus();
        }
        function close() {
          overlay!.hidden = true;
          document.body.style.overflow = "";
        }

        openBtn.addEventListener("click", open);
        backdrop?.addEventListener("click", close);
        input.addEventListener("input", () => render(input!.value));
        document.addEventListener("keydown", (ev) => {
          if (ev.key === "Escape" && !overlay!.hidden) close();
          // "/" でクイックオープン（入力中は除く）
          const tag = (ev.target as HTMLElement | null)?.tagName;
          if (ev.key === "/" && overlay!.hidden && tag !== "INPUT" && tag !== "TEXTAREA") {
            ev.preventDefault();
            open();
          }
        });
      }
    </script>
  </body>
</html>
