---
import SnsLinks from "./SnsLinks.astro";

interface Sns {
  x?: string;
  instagram?: string;
  tiktok?: string;
  youtube?: string;
  website?: string;
}

interface Props {
  name: string;
  href: string;
  subtitle?: string;
  meta?: string;
  badge?: { label: string; tone: "pass" | "fail" | "neutral" };
  sns?: Sns;
}

const { name, href, subtitle, meta, badge, sns } = Astro.props;
---

<article class="group rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-card)] p-4 hover:border-[var(--color-gold)] transition">
  <div class="flex items-start justify-between gap-3">
    <div class="min-w-0">
      <h3 class="font-semibold text-base">
        <a href={href} class="group-hover:text-[var(--color-gold-bright)] transition before:absolute before:inset-0">
          {name}
        </a>
      </h3>
      {subtitle && (
        <div class="text-xs text-[var(--color-text-muted)] mt-0.5">{subtitle}</div>
      )}
      {meta && <div class="text-xs text-[var(--color-text-muted)] mt-1">{meta}</div>}
    </div>
    {badge && (
      <span
        class:list={[
          "shrink-0 px-2 py-0.5 rounded text-[10px] font-semibold tracking-wider",
          badge.tone === "neutral" ? "" : "spoiler",
          badge.tone === "pass"
            ? "bg-[var(--color-gold)] text-black"
            : badge.tone === "fail"
              ? "bg-[var(--color-fail)] text-white"
              : "bg-[var(--color-bg-elevated)] text-[var(--color-text-muted)] border border-[var(--color-border)]",
        ]}
      >
        {badge.label}
      </span>
    )}
  </div>
  {sns && (
    <div class="mt-3 relative z-10">
      <SnsLinks sns={sns} size="sm" />
    </div>
  )}
</article>

<style>
  article {
    position: relative;
  }
</style>
