---
type VoteValue = "LAST CALL" | "NOTHING" | "NO CALL" | "ABSENT" | "UNKNOWN";

interface Props {
  vote: VoteValue;
  size?: "xs" | "sm" | "md" | "lg";
  round?: "first" | "final";
  queenName?: string;
  spoiler?: boolean;
}

const { vote, size = "sm", round, queenName, spoiler = true } = Astro.props;

const sizePx: Record<NonNullable<Props["size"]>, { box: string; text: string }> = {
  xs: { box: "w-4 h-4", text: "text-[8px]" },
  sm: { box: "w-6 h-6", text: "text-[10px]" },
  md: { box: "w-8 h-8", text: "text-[11px]" },
  lg: { box: "w-10 h-10", text: "text-xs" },
};

const variants: Record<VoteValue, string> = {
  "LAST CALL":
    "bg-[var(--color-gold)] text-black shadow-[inset_0_1px_0_rgba(255,255,255,0.4)]",
  NOTHING: "bg-[var(--color-fail)] text-white",
  "NO CALL":
    "bg-transparent text-[var(--color-text-muted)] border border-[var(--color-fail)]",
  ABSENT:
    "bg-[var(--color-surface)] text-[var(--color-text-subtle)] border border-[var(--color-border)]",
  UNKNOWN:
    "bg-transparent text-[var(--color-text-subtle)] border border-dashed border-[var(--color-border)]",
};

const labels: Record<VoteValue, string> = {
  "LAST CALL": "LC",
  NOTHING: "NO",
  "NO CALL": "NC",
  ABSENT: "—",
  UNKNOWN: "?",
};

const ariaLabel = (() => {
  const parts: string[] = [];
  if (queenName) parts.push(queenName);
  if (round) parts.push(round === "first" ? "ファースト" : "最終");
  parts.push(vote === "UNKNOWN" ? "未確認" : vote === "ABSENT" ? "欠席" : vote);
  return parts.join(" / ");
})();

const baseClass = "inline-flex items-center justify-center rounded-full font-bold leading-none tracking-tight transition-transform";

// UNKNOWN は元から判別不能 (?) なので occlusion 不要。
// それ以外で spoiler=true なら payload 化 (SSR では本値・aria・class を出さない)
const isOccluded = spoiler && vote !== "UNKNOWN";
const dataLevel: "vote" | undefined = vote === "LAST CALL" || vote === "NOTHING" ? "vote" : undefined;

const payload = isOccluded
  ? JSON.stringify({
      cls: variants[vote],
      label: labels[vote],
      aria: ariaLabel,
      vote,
    })
  : null;
---

{isOccluded ? (
  <span
    class:list={[baseClass, sizePx[size].box, sizePx[size].text, "lc-occluded"]}
    data-occlusion="chip"
    data-spoiler-level={dataLevel}
    data-spoiler-payload={payload}
    aria-label="ネタバレ非表示"
  ></span>
) : (
  <span
    class:list={[baseClass, sizePx[size].box, sizePx[size].text, variants[vote]]}
    aria-label={ariaLabel}
  >
    {labels[vote]}
  </span>
)}
