---
import { getEntries } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { siteLink } from "../lib/url";

interface Props {
  votes: CollectionEntry<"episodes">["data"]["votes"];
}

const { votes } = Astro.props;

const judgeEntries = await getEntries(votes.map((v) => v.judge));
const judgeMap = new Map(judgeEntries.map((j) => [j.id, j]));

const rows = votes.map((v) => ({
  vote: v.vote,
  comment: v.comment,
  judge: judgeMap.get(v.judge.id),
}));

const pass = votes.filter((v) => v.vote === "LAST CALL").length;
const fail = votes.filter((v) => v.vote === "NOTHING").length;
const absent = votes.filter((v) => v.vote === "ABSENT").length;
const total = pass + fail;
const result = total > 0 && pass >= Math.ceil(total / 2) ? "pass" : "fail";
---

<section class="space-y-4">
  <div class="flex flex-wrap items-end justify-between gap-3">
    <h2 class="font-display tracking-widest text-sm text-[var(--color-text-muted)] uppercase">
      Vote
    </h2>
    <div class="flex items-center gap-3 text-sm">
      <span class="inline-flex items-center gap-1.5">
        <span class="inline-block w-2.5 h-2.5 rounded-full bg-[var(--color-gold)]"></span>
        LAST CALL <span class="font-semibold text-[var(--color-gold)]">{pass}</span>
      </span>
      <span class="inline-flex items-center gap-1.5">
        <span class="inline-block w-2.5 h-2.5 rounded-full bg-[var(--color-fail)]"></span>
        NOTHING <span class="font-semibold text-[var(--color-text-muted)]">{fail}</span>
      </span>
      {absent > 0 && (
        <span class="inline-flex items-center gap-1.5 text-[var(--color-text-muted)]">
          欠席 {absent}
        </span>
      )}
      {total > 0 && (
        <span
          class:list={[
            "px-2 py-0.5 rounded text-xs font-semibold tracking-wider",
            result === "pass"
              ? "bg-[var(--color-gold)] text-black"
              : "bg-[var(--color-fail)] text-white",
          ]}
        >
          {result === "pass" ? "合格" : "不合格"}
        </span>
      )}
    </div>
  </div>

  <div class="overflow-x-auto rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-card)]">
    <table class="min-w-full text-sm">
      <thead class="bg-[var(--color-bg-elevated)] text-[var(--color-text-muted)]">
        <tr>
          <th class="text-left font-medium px-3 py-2 whitespace-nowrap">審査員</th>
          <th class="text-left font-medium px-3 py-2 whitespace-nowrap">投票</th>
          <th class="text-left font-medium px-3 py-2">コメント</th>
        </tr>
      </thead>
      <tbody>
        {rows.map((row) => (
          <tr class="border-t border-[var(--color-border)]">
            <td class="px-3 py-2 whitespace-nowrap">
              {row.judge ? (
                <a
                  href={siteLink(`/judges/${row.judge.id}/`)}
                  class="hover:text-[var(--color-gold-bright)] transition"
                >
                  {row.judge.data.name}
                </a>
              ) : (
                <span class="text-[var(--color-text-muted)]">未登録</span>
              )}
            </td>
            <td class="px-3 py-2 whitespace-nowrap">
              {row.vote === "LAST CALL" && (
                <span class="inline-flex items-center px-2 py-0.5 rounded bg-[var(--color-gold)] text-black text-xs font-semibold tracking-wider">
                  LAST CALL
                </span>
              )}
              {row.vote === "NOTHING" && (
                <span class="inline-flex items-center px-2 py-0.5 rounded bg-[var(--color-fail)] text-white text-xs font-semibold tracking-wider">
                  NOTHING
                </span>
              )}
              {row.vote === "ABSENT" && (
                <span class="inline-flex items-center px-2 py-0.5 rounded border border-[var(--color-border)] text-[var(--color-text-muted)] text-xs">
                  欠席
                </span>
              )}
            </td>
            <td class="px-3 py-2 text-[var(--color-text-muted)]">
              {row.comment ?? "—"}
            </td>
          </tr>
        ))}
        {rows.length === 0 && (
          <tr>
            <td colspan="3" class="px-3 py-6 text-center text-[var(--color-text-muted)]">
              投票データを準備中です。
            </td>
          </tr>
        )}
      </tbody>
    </table>
  </div>
</section>
