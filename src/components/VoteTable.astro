---
import { getCollection, getEntries } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { siteLink } from "../lib/url";
import VoteChip from "./VoteChip.astro";
import DivergingBar from "./DivergingBar.astro";
import SpoilerBadge from "./SpoilerBadge.astro";

interface Props {
  votes: CollectionEntry<"episodes">["data"]["votes"];
  cinderellaResult?: "pass" | "fail";
}

const { votes, cinderellaResult } = Astro.props;

type VoteValue = "LAST CALL" | "NOTHING" | "NO CALL" | "ABSENT" | "UNKNOWN";

const allJudges = (await getCollection("judges")).sort((a, b) =>
  a.data.name.localeCompare(b.data.name, "ja")
);

const recordedJudges = await getEntries(votes.map((v) => v.judge));
const judgeMap = new Map(recordedJudges.map((j) => [j.id, j]));
const extraVotes = votes.filter((v) => !allJudges.some((j) => j.id === v.judge.id));

const lookup = (judgeId: string, round: "first" | "final") =>
  votes.find((v) => v.judge.id === judgeId && v.round === round);

type Row = {
  judgeId: string;
  judgeName: string;
  judgeHref: string | null;
  first: { vote: VoteValue; comment?: string };
  final: { vote: VoteValue; comment?: string };
};

const baseRows: Row[] = allJudges.map((j) => {
  const f = lookup(j.id, "first");
  const l = lookup(j.id, "final");
  return {
    judgeId: j.id,
    judgeName: j.data.name,
    judgeHref: siteLink(`/judges/${j.id}/`),
    first: { vote: f ? f.vote : "UNKNOWN", comment: f?.comment },
    final: { vote: l ? l.vote : "UNKNOWN", comment: l?.comment },
  };
});

const extraJudgeIds = Array.from(new Set(extraVotes.map((v) => v.judge.id)));
const extraRows: Row[] = extraJudgeIds.map((id) => {
  const j = judgeMap.get(id);
  const f = lookup(id, "first");
  const l = lookup(id, "final");
  return {
    judgeId: id,
    judgeName: j?.data.name ?? "ゲスト審査員",
    judgeHref: j ? siteLink(`/judges/${j.id}/`) : null,
    first: { vote: f ? f.vote : "UNKNOWN", comment: f?.comment },
    final: { vote: l ? l.vote : "UNKNOWN", comment: l?.comment },
  };
});

const rows = [...baseRows, ...extraRows];

const tally = (round: "first" | "final") => {
  const list = rows.map((r) => r[round].vote);
  return {
    lastCall: list.filter((v) => v === "LAST CALL").length,
    nothing: list.filter((v) => v === "NOTHING").length,
    noCall: list.filter((v) => v === "NO CALL").length,
    absent: list.filter((v) => v === "ABSENT").length,
    unknown: list.filter((v) => v === "UNKNOWN").length,
  };
};
const firstTally = tally("first");
const finalTally = tally("final");

const finalPass = finalTally.lastCall;
const finalFail = finalTally.nothing + finalTally.noCall;
const totalRecorded = finalPass + finalFail;
const calcResult: "pass" | "fail" | null =
  totalRecorded > 0 ? (finalPass >= Math.ceil(totalRecorded / 2) ? "pass" : "fail") : null;
const displayResult = cinderellaResult ?? calcResult;

const flipped = rows.filter((r) => {
  if (r.first.vote === "UNKNOWN" || r.final.vote === "UNKNOWN") return false;
  const firstPass = r.first.vote === "LAST CALL";
  const finalPass = r.final.vote === "LAST CALL";
  return firstPass !== finalPass;
}).length;

const hasAnyVote = votes.length > 0;
---

<section class="space-y-6">
  <header class="flex flex-wrap items-end justify-between gap-3">
    <div class="space-y-1">
      <h2 class="section-eyebrow">Judges &amp; Votes</h2>
      <p class="text-xs text-[var(--color-text-muted)] tracking-wide">
        固定 14 名審査員 × 2 ラウンド（ファーストコール / 最終ジャッジ）
      </p>
    </div>
    {displayResult && (
      <SpoilerBadge result={displayResult} variant="pill-large" />
    )}
  </header>

  {/* Diverging bar — Final */}
  <div class="card p-5 sm:p-6 space-y-5">
    <DivergingBar
      pass={finalTally.lastCall}
      fail={finalTally.nothing + finalTally.noCall}
      absent={finalTally.absent}
      unknown={finalTally.unknown}
      label="最終ジャッジ (Final)"
      size="lg"
      spoilerLevel="result"
    />
    <DivergingBar
      pass={firstTally.lastCall}
      fail={firstTally.nothing + firstTally.noCall}
      absent={firstTally.absent}
      unknown={firstTally.unknown}
      label="ファーストコール (First)"
      size="sm"
      spoilerLevel="vote"
    />
    {flipped > 0 && (
      <p class="text-[11px] text-[var(--color-text-muted)] tracking-wide">
        ファースト → 最終で判定変更:
        <span
          class="lc-occluded relative font-semibold text-[var(--color-text)] tabular-nums"
          data-occlusion="text"
          data-spoiler-level="vote"
          data-spoiler-payload={JSON.stringify({ text: String(flipped), aria: `${flipped} 名` })}
          aria-label="人数（非表示）"
        ><span class="lc-payload-content"></span></span> 名
      </p>
    )}
  </div>

  {/* Judge signature row — 14 chips */}
  <div class="card p-4 sm:p-5 space-y-3">
    <div class="flex items-baseline justify-between gap-3">
      <h3 class="text-[11px] tracking-[0.24em] uppercase text-[var(--color-text-subtle)] font-medium">
        Vote Signature
      </h3>
      <span class="text-[10px] text-[var(--color-text-subtle)] tracking-wider">
        上=First / 下=Final
      </span>
    </div>
    <div class="flex flex-wrap gap-1.5 sm:gap-2">
      {rows.map((r) => (
        <a href={r.judgeHref ?? "#"} class="group flex flex-col items-center gap-0.5">
          <span class="flex flex-col items-center gap-0.5">
            <VoteChip vote={r.first.vote} size="sm" round="first" judgeName={r.judgeName} />
            <VoteChip vote={r.final.vote} size="sm" round="final" judgeName={r.judgeName} />
          </span>
          <span class="text-[9px] leading-none text-[var(--color-text-subtle)] tracking-tight group-hover:text-[var(--color-gold-bright)] transition max-w-[60px] truncate text-center">
            {r.judgeName}
          </span>
        </a>
      ))}
    </div>
  </div>

  {/* Detail table — collapsed by default */}
  {hasAnyVote && (
    <details class="card group">
      <summary class="px-5 sm:px-6 py-3 cursor-pointer list-none flex items-center justify-between gap-3 text-sm tracking-wide select-none">
        <span class="flex items-center gap-2">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="transition group-open:rotate-90" aria-hidden="true">
            <polyline points="9 18 15 12 9 6"/>
          </svg>
          票の詳細 & コメント
        </span>
        <span class="text-[10px] text-[var(--color-text-subtle)] tracking-wider uppercase">
          {votes.length} 票記録
        </span>
      </summary>
      <div class="border-t border-[var(--color-border)] overflow-x-auto">
        <table class="min-w-full text-sm">
          <thead class="bg-[var(--color-surface)] text-[var(--color-text-muted)]">
            <tr>
              <th class="text-left font-medium px-3 py-2 whitespace-nowrap">審査員</th>
              <th class="text-center font-medium px-3 py-2 whitespace-nowrap">First</th>
              <th class="text-center font-medium px-3 py-2 whitespace-nowrap">Final</th>
              <th class="text-left font-medium px-3 py-2">コメント</th>
            </tr>
          </thead>
          <tbody>
            {rows.map((row) => {
              const comments: string[] = [];
              if (row.first.comment) comments.push(`（ファースト）${row.first.comment}`);
              if (row.final.comment) comments.push(`（最終）${row.final.comment}`);
              return (
                <tr class="border-t border-[var(--color-border)] hover:bg-[color-mix(in_oklab,var(--color-gold)_3%,transparent)] transition">
                  <td class="px-3 py-2 whitespace-nowrap">
                    {row.judgeHref ? (
                      <a href={row.judgeHref} class="hover:text-[var(--color-gold-bright)] transition">
                        {row.judgeName}
                      </a>
                    ) : (
                      <span>{row.judgeName}</span>
                    )}
                  </td>
                  <td class="px-3 py-2 text-center">
                    <VoteChip vote={row.first.vote} size="sm" round="first" judgeName={row.judgeName} />
                  </td>
                  <td class="px-3 py-2 text-center">
                    <VoteChip vote={row.final.vote} size="sm" round="final" judgeName={row.judgeName} />
                  </td>
                  <td class="px-3 py-2 text-[var(--color-text-muted)] text-xs sm:text-sm leading-relaxed">
                    {comments.length > 0 ? (
                      <span
                        class="lc-occluded relative block"
                        data-occlusion="block"
                        data-spoiler-level="comment"
                        data-spoiler-payload={JSON.stringify({ text: comments.join(" / "), aria: "コメント" })}
                        aria-label="コメント（非表示）"
                      ><span class="lc-payload-content"></span></span>
                    ) : "—"}
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </details>
  )}

  {finalTally.unknown > 0 && (
    <p class="text-[11px] text-[var(--color-text-subtle)] tracking-wide">
      「未確認」は本編未視聴のため個別投票が未記録の審査員です。<code class="text-[var(--color-text-muted)]">src/content/episodes/{Astro.url.pathname.match(/episodes\/(\d+)/)?.[1] ?? "<ID>"}.json</code> の <code class="text-[var(--color-text-muted)]">votes</code> に <code class="text-[var(--color-text-muted)]">round: "first" | "final"</code> 指定で追加してください。
    </p>
  )}
</section>
