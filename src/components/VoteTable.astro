---
import { getCollection, getEntries } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { siteLink } from "../lib/url";

interface Props {
  votes: CollectionEntry<"episodes">["data"]["votes"];
  cinderellaResult?: "pass" | "fail";
}

const { votes, cinderellaResult } = Astro.props;

type VoteValue = "LAST CALL" | "NOTHING" | "NO CALL" | "ABSENT" | "UNKNOWN";

const allJudges = (await getCollection("judges")).sort((a, b) =>
  a.data.name.localeCompare(b.data.name, "ja")
);

const recordedJudges = await getEntries(votes.map((v) => v.judge));
const judgeMap = new Map(recordedJudges.map((j) => [j.id, j]));
const extraVotes = votes.filter((v) => !allJudges.some((j) => j.id === v.judge.id));

const lookup = (judgeId: string, round: "first" | "final") =>
  votes.find((v) => v.judge.id === judgeId && v.round === round);

type Row = {
  judgeId: string;
  judgeName: string;
  judgeHref: string | null;
  first: { vote: VoteValue; comment?: string };
  final: { vote: VoteValue; comment?: string };
};

const baseRows: Row[] = allJudges.map((j) => {
  const f = lookup(j.id, "first");
  const l = lookup(j.id, "final");
  return {
    judgeId: j.id,
    judgeName: j.data.name,
    judgeHref: siteLink(`/judges/${j.id}/`),
    first: { vote: f ? f.vote : "UNKNOWN", comment: f?.comment },
    final: { vote: l ? l.vote : "UNKNOWN", comment: l?.comment },
  };
});

const extraJudgeIds = Array.from(new Set(extraVotes.map((v) => v.judge.id)));
const extraRows: Row[] = extraJudgeIds.map((id) => {
  const j = judgeMap.get(id);
  const f = lookup(id, "first");
  const l = lookup(id, "final");
  return {
    judgeId: id,
    judgeName: j?.data.name ?? "ゲスト審査員",
    judgeHref: j ? siteLink(`/judges/${j.id}/`) : null,
    first: { vote: f ? f.vote : "UNKNOWN", comment: f?.comment },
    final: { vote: l ? l.vote : "UNKNOWN", comment: l?.comment },
  };
});

const rows = [...baseRows, ...extraRows];

// 各ラウンドごとに集計
const tally = (round: "first" | "final") => {
  const list = votes.filter((v) => v.round === round);
  return {
    lastCall: list.filter((v) => v.vote === "LAST CALL").length,
    nothing: list.filter((v) => v.vote === "NOTHING").length,
    noCall: list.filter((v) => v.vote === "NO CALL").length,
    absent: list.filter((v) => v.vote === "ABSENT").length,
    unknown: rows.filter((r) => r[round].vote === "UNKNOWN").length,
  };
};
const firstTally = tally("first");
const finalTally = tally("final");

// 合否判定は最終ジャッジのみで集計
const pass = finalTally.lastCall;
const fail = finalTally.nothing + finalTally.noCall;
const totalRecorded = pass + fail;
const calcResult: "pass" | "fail" | null =
  totalRecorded > 0 ? (pass >= Math.ceil(totalRecorded / 2) ? "pass" : "fail") : null;
const displayResult = cinderellaResult ?? calcResult;

// ファースト → 最終で判定が変わった審査員数（両ラウンドとも記録があるもののみ）
const flipped = rows.filter((r) => {
  if (r.first.vote === "UNKNOWN" || r.final.vote === "UNKNOWN") return false;
  const firstPass = r.first.vote === "LAST CALL";
  const finalPass = r.final.vote === "LAST CALL";
  return firstPass !== finalPass;
}).length;

const renderBadge = (vote: VoteValue) => vote;
---

<section class="space-y-4">
  <div class="flex flex-wrap items-end justify-between gap-3">
    <h2 class="font-display tracking-widest text-sm text-[var(--color-text-muted)] uppercase">
      Judges &amp; Vote
    </h2>
    {displayResult && (
      <span
        class:list={[
          "spoiler px-3 py-1 rounded text-sm font-semibold tracking-wider",
          displayResult === "pass"
            ? "bg-[var(--color-gold)] text-black"
            : "bg-[var(--color-fail)] text-white",
        ]}
      >
        {displayResult === "pass" ? "合格" : "不合格"}
      </span>
    )}
  </div>

  <div class="grid sm:grid-cols-2 gap-2 text-xs">
    {([
      { key: "first" as const, label: "ファーストコール", t: firstTally },
      { key: "final" as const, label: "最終ジャッジ", t: finalTally },
    ]).map(({ key, label, t }) => (
      <div class="rounded-md border border-[var(--color-border)] bg-[var(--color-bg-elevated)] px-3 py-2">
        <div class="flex items-center justify-between mb-1">
          <span class="font-semibold text-[var(--color-text)]">{label}</span>
          <span class="text-[10px] text-[var(--color-text-subtle)] uppercase tracking-wider">
            {key === "first" ? "First Call" : "Final Judgment"}
          </span>
        </div>
        <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-[var(--color-text-muted)]">
          <span class="spoiler inline-flex items-center gap-1">
            <span class="inline-block w-2 h-2 rounded-full bg-[var(--color-gold)]"></span>
            LC <span class="font-semibold text-[var(--color-gold)]">{t.lastCall}</span>
          </span>
          <span class="spoiler inline-flex items-center gap-1">
            <span class="inline-block w-2 h-2 rounded-full bg-[var(--color-fail)]"></span>
            NOTHING <span class="font-semibold text-[var(--color-text)]">{t.nothing}</span>
          </span>
          <span class="spoiler inline-flex items-center gap-1">
            <span class="inline-block w-2 h-2 rounded-full border border-[var(--color-fail)]"></span>
            NO CALL <span class="font-semibold text-[var(--color-text)]">{t.noCall}</span>
          </span>
          {t.absent > 0 && (
            <span class="spoiler inline-flex items-center gap-1">欠席 {t.absent}</span>
          )}
          {t.unknown > 0 && (
            <span class="inline-flex items-center gap-1">未確認 {t.unknown}</span>
          )}
        </div>
      </div>
    ))}
  </div>

  {flipped > 0 && (
    <p class="spoiler text-xs text-[var(--color-text-muted)]">
      ファースト→最終で判定を変えた審査員：
      <span class="font-semibold text-[var(--color-text)]">{flipped}</span> 名
    </p>
  )}

  <div class="overflow-x-auto rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-card)]">
    <table class="min-w-full text-sm">
      <thead class="bg-[var(--color-bg-elevated)] text-[var(--color-text-muted)]">
        <tr>
          <th class="text-left font-medium px-3 py-2 whitespace-nowrap">審査員</th>
          <th class="text-left font-medium px-3 py-2 whitespace-nowrap">
            ファーストコール
            <span class="block text-[10px] font-normal text-[var(--color-text-subtle)] normal-case">First Call</span>
          </th>
          <th class="text-left font-medium px-3 py-2 whitespace-nowrap">
            最終ジャッジ
            <span class="block text-[10px] font-normal text-[var(--color-text-subtle)] normal-case">Final Judgment</span>
          </th>
          <th class="text-left font-medium px-3 py-2">コメント</th>
        </tr>
      </thead>
      <tbody>
        {rows.map((row) => {
          const comments: string[] = [];
          if (row.first.comment) comments.push(`（ファースト）${row.first.comment}`);
          if (row.final.comment) comments.push(`（最終）${row.final.comment}`);
          return (
            <tr class="border-t border-[var(--color-border)]">
              <td class="px-3 py-2 whitespace-nowrap">
                {row.judgeHref ? (
                  <a
                    href={row.judgeHref}
                    class="hover:text-[var(--color-gold-bright)] transition"
                  >
                    {row.judgeName}
                  </a>
                ) : (
                  <span>{row.judgeName}</span>
                )}
              </td>
              {(["first", "final"] as const).map((round) => {
                const cell = row[round];
                return (
                  <td class="px-3 py-2 whitespace-nowrap">
                    {cell.vote === "LAST CALL" && (
                      <span class="spoiler inline-flex items-center px-2 py-0.5 rounded bg-[var(--color-gold)] text-black text-xs font-semibold tracking-wider">
                        {renderBadge(cell.vote)}
                      </span>
                    )}
                    {cell.vote === "NOTHING" && (
                      <span class="spoiler inline-flex items-center px-2 py-0.5 rounded bg-[var(--color-fail)] text-white text-xs font-semibold tracking-wider">
                        {renderBadge(cell.vote)}
                      </span>
                    )}
                    {cell.vote === "NO CALL" && (
                      <span class="spoiler inline-flex items-center px-2 py-0.5 rounded border border-[var(--color-fail)] text-[var(--color-fail)] text-xs font-semibold tracking-wider">
                        {renderBadge(cell.vote)}
                      </span>
                    )}
                    {cell.vote === "ABSENT" && (
                      <span class="spoiler inline-flex items-center px-2 py-0.5 rounded border border-[var(--color-border)] text-[var(--color-text-muted)] text-xs">
                        欠席
                      </span>
                    )}
                    {cell.vote === "UNKNOWN" && (
                      <span class="inline-flex items-center px-2 py-0.5 rounded border border-dashed border-[var(--color-border)] text-[var(--color-text-muted)] text-xs">
                        未確認
                      </span>
                    )}
                  </td>
                );
              })}
              <td class="px-3 py-2 text-[var(--color-text-muted)]">
                {comments.length > 0
                  ? <span class="spoiler-block inline-block">{comments.join(" / ")}</span>
                  : "—"}
              </td>
            </tr>
          );
        })}
      </tbody>
    </table>
  </div>
  {finalTally.unknown > 0 && (
    <p class="text-xs text-[var(--color-text-muted)]">
      「未確認」は本編未視聴により個別投票が記録されていない審査員です。視聴後に
      <code class="text-[var(--color-text)]">src/content/episodes/{Astro.url.pathname.match(/episodes\/(\d+)/)?.[1]}.json</code>
      の <code class="text-[var(--color-text)]">votes</code> 配列に
      <code class="text-[var(--color-text)]">round: "first"</code> / <code class="text-[var(--color-text)]">round: "final"</code>
      を指定して埋めると反映されます。
    </p>
  )}
</section>
