---
import { getEntries } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { siteLink } from "../lib/url";
import VoteChip from "./VoteChip.astro";
import DivergingBar from "./DivergingBar.astro";
import SpoilerBadge from "./SpoilerBadge.astro";

interface Props {
  lineup: CollectionEntry<"episodes">["data"]["lineup"];
  votes: CollectionEntry<"episodes">["data"]["votes"];
  cinderellaResult?: "pass" | "fail";
}

const { lineup, votes, cinderellaResult } = Astro.props;

type VoteValue = "LIKE" | "NOTHING" | "合格" | "不合格" | "UNKNOWN";

// 出演クイーンのラインナップ（回ごとに可変）。順序は lineup の指定順。
const lineupQueens = await getEntries(lineup);

const lookup = (queenId: string, round: "first" | "final") =>
  votes.find((v) => v.queen.id === queenId && v.round === round);

type Row = {
  queenId: string;
  queenName: string;
  queenHref: string;
  first: { vote: VoteValue };
  final: { vote: VoteValue };
};

const rows: Row[] = lineupQueens.map((j) => {
  const f = lookup(j.id, "first");
  const l = lookup(j.id, "final");
  return {
    queenId: j.id,
    queenName: j.data.name,
    queenHref: siteLink(`/queens/${j.id}/`),
    first: { vote: (f ? f.vote : "UNKNOWN") as VoteValue },
    final: { vote: (l ? l.vote : "UNKNOWN") as VoteValue },
  };
});

const tallyFirst = {
  lastCall: rows.filter((r) => r.first.vote === "LIKE").length,
  nothing: rows.filter((r) => r.first.vote === "NOTHING").length,
  unknown: rows.filter((r) => r.first.vote === "UNKNOWN").length,
};
const tallyFinal = {
  pass: rows.filter((r) => r.final.vote === "合格").length,
  fail: rows.filter((r) => r.final.vote === "不合格").length,
  unknown: rows.filter((r) => r.final.vote === "UNKNOWN").length,
};

const totalRecorded = tallyFinal.pass + tallyFinal.fail;
const calcResult: "pass" | "fail" | null =
  totalRecorded > 0 ? (tallyFinal.pass >= Math.ceil(totalRecorded / 2) ? "pass" : "fail") : null;
const displayResult = cinderellaResult ?? calcResult;

const flipped = rows.filter((r) => {
  if (r.first.vote === "UNKNOWN" || r.final.vote === "UNKNOWN") return false;
  const firstPass = r.first.vote === "LIKE";
  const finalPass = r.final.vote === "合格";
  return firstPass !== finalPass;
}).length;

const hasLineup = rows.length > 0;
const hasAnyVote = votes.length > 0;
---

<section class="space-y-6">
  <header class="flex flex-wrap items-end justify-between gap-3">
    <div class="space-y-1">
      <h2 class="section-eyebrow">Queens &amp; Votes</h2>
      <p class="text-xs text-[var(--color-text-muted)] tracking-wide">
        出演クイーン {hasLineup ? `${rows.length} 名` : ""} × 2 ラウンド（ファーストコール / 最終ジャッジ）
      </p>
    </div>
    {displayResult && (
      <SpoilerBadge result={displayResult} variant="pill-large" />
    )}
  </header>

  {hasLineup ? (
    <Fragment>
      {/* Diverging bar — Final / First */}
      <div class="card p-5 sm:p-6 space-y-5">
        <DivergingBar
          pass={tallyFinal.pass}
          fail={tallyFinal.fail}
          unknown={tallyFinal.unknown}
          label="最終ジャッジ (Final)"
          size="lg"
          spoilerLevel="result"
        />
        <DivergingBar
          pass={tallyFirst.lastCall}
          fail={tallyFirst.nothing}
          unknown={tallyFirst.unknown}
          label="ファーストコール (First)"
          size="sm"
          spoilerLevel="vote"
          terms={{ pass: "LIKE", fail: "NOTHING" }}
        />
        {flipped > 0 && (
          <p class="text-[11px] text-[var(--color-text-muted)] tracking-wide">
            ファースト → 最終で判定変更:
            <span
              class="lc-occluded relative font-semibold text-[var(--color-text)] tabular-nums"
              data-occlusion="text"
              data-spoiler-level="vote"
              data-spoiler-payload={JSON.stringify({ text: String(flipped), aria: `${flipped} 名` })}
              aria-label="人数（非表示）"
            ><span class="lc-payload-content"></span></span> 名
          </p>
        )}
      </div>

      {/* Queen signature row */}
      <div class="card p-4 sm:p-5 space-y-3">
        <div class="flex items-baseline justify-between gap-3">
          <h3 class="text-[11px] tracking-[0.24em] uppercase text-[var(--color-text-subtle)] font-medium">
            Vote Signature
          </h3>
          <span class="text-[10px] text-[var(--color-text-subtle)] tracking-wider">
            上=First / 下=Final
          </span>
        </div>
        <div class="flex flex-wrap gap-1.5 sm:gap-2">
          {rows.map((r) => (
            <a href={r.queenHref} class="group flex flex-col items-center gap-0.5">
              <span class="flex flex-col items-center gap-0.5">
                <VoteChip vote={r.first.vote} size="sm" round="first" queenName={r.queenName} />
                <VoteChip vote={r.final.vote} size="sm" round="final" queenName={r.queenName} />
              </span>
              <span class="text-[9px] leading-none text-[var(--color-text-subtle)] tracking-tight group-hover:text-[var(--color-gold-bright)] transition max-w-[60px] truncate text-center">
                {r.queenName}
              </span>
            </a>
          ))}
        </div>
      </div>

      {/* Detail table — collapsed by default */}
      {hasAnyVote && (
        <details class="card group">
          <summary class="px-5 sm:px-6 py-3 cursor-pointer list-none flex items-center justify-between gap-3 text-sm tracking-wide select-none">
            <span class="flex items-center gap-2">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="transition group-open:rotate-90" aria-hidden="true">
                <polyline points="9 18 15 12 9 6"/>
              </svg>
              票の詳細
            </span>
            <span class="text-[10px] text-[var(--color-text-subtle)] tracking-wider uppercase">
              {votes.length} 票記録
            </span>
          </summary>
          <div class="border-t border-[var(--color-border)] overflow-x-auto">
            <table class="min-w-full text-sm">
              <thead class="bg-[var(--color-surface)] text-[var(--color-text-muted)]">
                <tr>
                  <th class="text-left font-medium px-3 py-2 whitespace-nowrap">クイーン</th>
                  <th class="text-center font-medium px-3 py-2 whitespace-nowrap">First</th>
                  <th class="text-center font-medium px-3 py-2 whitespace-nowrap">Final</th>
                </tr>
              </thead>
              <tbody>
                {rows.map((row) => (
                  <tr class="border-t border-[var(--color-border)] hover:bg-[color-mix(in_oklab,var(--color-gold)_3%,transparent)] transition">
                    <td class="px-3 py-2 whitespace-nowrap">
                      <a href={row.queenHref} class="hover:text-[var(--color-gold-bright)] transition">
                        {row.queenName}
                      </a>
                    </td>
                    <td class="px-3 py-2 text-center">
                      <VoteChip vote={row.first.vote} size="sm" round="first" queenName={row.queenName} />
                    </td>
                    <td class="px-3 py-2 text-center">
                      <VoteChip vote={row.final.vote} size="sm" round="final" queenName={row.queenName} />
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </details>
      )}

      {tallyFinal.unknown > 0 && (
        <p class="text-[11px] text-[var(--color-text-subtle)] tracking-wide">
          「未確認」はラインナップに含まれるが個別投票が未記録のクイーンです。<code class="text-[var(--color-text-muted)]">npm run edit</code> のエディタで各クイーンの票を入力できます。
        </p>
      )}
    </Fragment>
  ) : (
    <p class="text-sm text-[var(--color-text-muted)] tracking-wide card p-5">
      出演クイーンのラインナップが未記録です。<code class="text-[var(--color-text-muted)]">npm run edit</code> のエディタでラインナップと票を入力してください。
    </p>
  )}
</section>
