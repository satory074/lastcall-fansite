---

{
  visible.length > 0 && (
    <ul class="flex flex-wrap items-center gap-2">
      {visible.map((item) => (
        <li>
          <a
            href={sns[item.key]}
            target="_blank"
            rel="noopener nofollow"
            class:list={[
              "inline-flex items-center gap-1.5 rounded-full border border-[var(--color-border)] bg-[var(--color-bg-elevated)] text-[var(--color-text-muted)] hover:text-[var(--color-gold-bright)] hover:border-[var(--color-gold)] transition",
              padding,
            ]}
            aria-label={item.label}
            title={item.label}
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              width={iconSize}
              height={iconSize}
              fill="currentColor"
              aria-hidden="true"
            >
              <path d={item.icon} />
            </svg>
            <span class="sr-only">{item.label}</span>
          </a>
        </li>
      ))}
    </ul>
  )
}
