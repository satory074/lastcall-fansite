---
interface Props {
  pass: number;
  fail: number;
  absent?: number;
  unknown?: number;
  label?: string;
  size?: "sm" | "md" | "lg";
  spoiler?: boolean;
  spoilerLevel?: "result" | "vote" | "comment";
  showLabels?: boolean;
  // 合格率 % ラベルを表示するか（false で非表示）
  showRate?: boolean;
  // true で 合格(金)を左・不合格(灰)を右に反転
  flip?: boolean;
  // aria 用の票種ラベル。最終=合格/不合格、ファースト=LIKE/NOTHING など。
  terms?: { pass: string; fail: string };
}

const {
  pass,
  fail,
  absent = 0,
  unknown = 0,
  label,
  size = "md",
  spoiler = true,
  spoilerLevel = "result",
  showLabels = true,
  showRate = true,
  flip = false,
  terms = { pass: "合格", fail: "不合格" },
} = Astro.props;

const recorded = pass + fail;
const total = pass + fail + absent;
const passRate = recorded > 0 ? Math.round((pass / recorded) * 100) : null;

const heights: Record<NonNullable<Props["size"]>, string> = {
  sm: "h-1.5",
  md: "h-2.5",
  lg: "h-3.5",
};

// 中心 0 基準の票割合 (％ 幅)。記録 0 件のときは中央線のみ
const passPct = recorded > 0 ? (pass / recorded) * 50 : 0;
const failPct = recorded > 0 ? (fail / recorded) * 50 : 0;

const showRateLabel = showRate && passRate !== null;
const labelAria = recorded > 0
  ? `${terms.pass} ${pass} / ${terms.fail} ${fail}${showRateLabel ? ` (合格率 ${passRate}%)` : ""}`
  : "投票データなし";

// 数値 span（flip 時は 合格(金) を左に）
const failSpan = `<span class=\"text-[var(--color-fail)] font-semibold\">${fail}</span>`;
const passSpan = `<span class=\"text-[var(--color-gold)] font-semibold\">${pass}</span>`;
const dotSpan = `<span class=\"mx-1 text-[var(--color-border-strong)]\">·</span>`;

// テキスト行 (数値 + 合格率) の payload — innerHTML で復元
const textPayload = spoiler && recorded > 0
  ? JSON.stringify({
      html: (flip ? passSpan + dotSpan + failSpan : failSpan + dotSpan + passSpan) +
            (showRateLabel ? `<span class=\"ml-2 text-[var(--color-text-subtle)]\">合格率 ${passRate}%</span>` : ""),
      aria: labelAria,
    })
  : null;

// バー本体の payload
const barPayload = spoiler && recorded > 0
  ? JSON.stringify({ failPct, passPct, aria: labelAria })
  : null;

// バーの左右（flip 時は 合格(金) を左・不合格(灰) を右に）
const failSide = flip ? "left-1/2 origin-left" : "right-1/2 origin-right";
const passSide = flip ? "right-1/2 origin-right" : "left-1/2 origin-left";
---

<div class="space-y-2">
  {(label || showLabels) && (
    <div class="flex flex-wrap items-baseline justify-between gap-2 text-[11px] text-[var(--color-text-muted)]">
      {label && (
        <span class="font-medium tracking-wider uppercase text-[10px] text-[var(--color-text-subtle)]">
          {label}
        </span>
      )}
      {showLabels && recorded > 0 && (
        spoiler ? (
          <span
            class="tabular-nums lc-occluded relative"
            data-occlusion="text"
            data-spoiler-level={spoilerLevel}
            data-spoiler-payload={textPayload}
            aria-label="投票数（非表示）"
          ><span class="lc-payload-content"></span></span>
        ) : (
          <span class="tabular-nums" aria-label={labelAria}>
            <span class={`font-semibold ${flip ? "text-[var(--color-gold)]" : "text-[var(--color-fail)]"}`}>{flip ? pass : fail}</span>
            <span class="mx-1 text-[var(--color-border-strong)]">·</span>
            <span class={`font-semibold ${flip ? "text-[var(--color-fail)]" : "text-[var(--color-gold)]"}`}>{flip ? fail : pass}</span>
            {showRateLabel && (
              <span class="ml-2 text-[var(--color-text-subtle)]">合格率 {passRate}%</span>
            )}
          </span>
        )
      )}
    </div>
  )}
  {spoiler && recorded > 0 ? (
    <div
      class:list={[
        "relative rounded-full bg-[var(--color-surface)] border border-[var(--color-border)] overflow-hidden lc-occluded",
        heights[size],
      ]}
      data-occlusion="bar"
      data-spoiler-level={spoilerLevel}
      data-spoiler-payload={barPayload}
      aria-label="投票結果（非表示）"
    >
      {/* center axis */}
      <div class="absolute top-0 bottom-0 left-1/2 w-px bg-[var(--color-border-strong)] z-10"></div>
      {/* fail bar — 既定=左 / flip=右 (SSR では width:0、hydrator が設定) */}
      <div
        data-bar="fail"
        class:list={["absolute top-0 bottom-0 bg-[var(--color-fail)]", failSide]}
        style="width: 0%"
      ></div>
      {/* pass bar — 既定=右 / flip=左 (SSR では width:0、hydrator が設定) */}
      <div
        data-bar="pass"
        class:list={["absolute top-0 bottom-0 bg-gradient-to-r from-[var(--color-gold-deep)] to-[var(--color-gold)]", passSide]}
        style="width: 0%"
      ></div>
    </div>
  ) : (
    <div
      class:list={[
        "relative rounded-full bg-[var(--color-surface)] border border-[var(--color-border)] overflow-hidden",
        heights[size],
      ]}
      aria-label={labelAria}
    >
      <div class="absolute top-0 bottom-0 left-1/2 w-px bg-[var(--color-border-strong)] z-10"></div>
      {failPct > 0 && (
        <div
          class:list={["absolute top-0 bottom-0 bg-[var(--color-fail)]", failSide]}
          style={`width: ${failPct}%`}
        ></div>
      )}
      {passPct > 0 && (
        <div
          class:list={["absolute top-0 bottom-0 bg-gradient-to-r from-[var(--color-gold-deep)] to-[var(--color-gold)]", passSide]}
          style={`width: ${passPct}%`}
        ></div>
      )}
    </div>
  )}
  {(absent > 0 || unknown > 0) && (
    <div class="text-[10px] text-[var(--color-text-subtle)] tracking-wider">
      {absent > 0 && <span>欠席 {absent}</span>}
      {absent > 0 && unknown > 0 && <span class="mx-1">·</span>}
      {unknown > 0 && <span>未確認 {unknown}</span>}
      <span class="ml-2">/ 合計 {total + unknown}</span>
    </div>
  )}
</div>
